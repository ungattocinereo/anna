<script>
  // Nav scroll behavior
  const nav = document.getElementById('nav');
  const waFloat = document.getElementById('waFloat');
  const hero = document.getElementById('hero');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
      if (waFloat && hero) {
        waFloat.classList.toggle('visible', window.scrollY > hero.offsetHeight);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Burger menu
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobileMenu');
  if (burger && mobileMenu) {
    burger.addEventListener('click', () => {
      burger.classList.toggle('active');
      mobileMenu.classList.toggle('open');
      document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
    });
    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', () => {
        burger.classList.remove('active');
        mobileMenu.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const parent = entry.target.closest('.gallery-grid, .reviews-track, .boats-grid, .stops-list, .tour-features-grid');
        const delay = parent ? Array.from(parent.children).indexOf(entry.target) * 100 : 0;
        setTimeout(() => entry.target.classList.add('visible'), delay);
        revealObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  revealEls.forEach(el => revealObs.observe(el));

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (href && href !== '#') {
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });

  // Toggle handler for collapsible sections
  document.querySelectorAll('[data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const id = header.getAttribute('data-toggle');
      if (!id) return;
      const content = document.getElementById(id);
      if (!content) return;
      content.classList.toggle('open');
      const toggle = header.querySelector('.tour-toggle');
      if (toggle) toggle.classList.toggle('rotated');
    });
  });

  // Reviews carousel
  const track = document.getElementById('reviewsTrack');
  const prevBtn = document.querySelector('.review-prev');
  const nextBtn = document.querySelector('.review-next');
  if (track && prevBtn && nextBtn) {
    const scrollAmt = 400;
    prevBtn.addEventListener('click', () => track.scrollBy({ left: -scrollAmt, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => track.scrollBy({ left: scrollAmt, behavior: 'smooth' }));
  }

  // Telegram contact form
  const form = document.getElementById('contactForm');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = form.querySelector('[name="name"]').value;
    const contact = form.querySelector('[name="contact"]').value;
    const message = form.querySelector('[name="message"]').value;
    const text = `📩 Новая заявка с сайта anna.amalfi.day\n\n👤 Имя: ${name}\n📱 Контакт: ${contact}\n💬 Сообщение: ${message}`;
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Отправка...';
    try {
      const botToken = 'BOT_TOKEN_PLACEHOLDER';
      const chatId = 'CHAT_ID_PLACEHOLDER';
      const res = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text, parse_mode: 'HTML' }),
      });
      if (res.ok) {
        form.innerHTML = '<p class="form-success">Спасибо! Ваше сообщение отправлено. Я свяжусь с вами в ближайшее время!</p>';
      } else {
        throw new Error();
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Отправить';
      alert('Ошибка отправки. Пожалуйста, напишите напрямую в WhatsApp или Telegram.');
    }
  });
</script>

</body>
