// v1.astro — "Dolce Vita" Editorial Luxury Magazine design

const INSTAGRAM_TOKEN = import.meta.env.INSTAGRAM_TOKEN;
let instagramPhotos = [];
let isLive = false;
if (INSTAGRAM_TOKEN) {
  try {
    const res = await fetch(`https://graph.instagram.com/me/media?fields=id,caption,media_url,permalink,thumbnail_url,media_type&limit=20&access_token=${INSTAGRAM_TOKEN}`);
    if (res.ok) {
      const data = await res.json();
      instagramPhotos = data.data.slice(0, 8).map((item) => ({
        src: item.media_type === 'VIDEO' ? item.thumbnail_url : item.media_url,
        alt: item.caption?.slice(0, 80) || 'Instagram фото',
        permalink: item.permalink,
      }));
      if (instagramPhotos.length >= 4) isLive = true;
    }
  } catch (e) {}
}
const fallbackPhotos = [
  { src: '/images/20250630_195957.jpg', alt: 'Positano', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241030_111216.jpg', alt: 'Амальфитанское побережье', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241104_150159.jpg', alt: 'Побережье', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241125_113727.jpg', alt: 'Виды', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241006_175944.jpg', alt: 'Закат', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241127_105410.jpg', alt: 'Побережье', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20250420_084358.jpg', alt: 'Экскурсия', permalink: 'https://www.instagram.com/ann_in_rome/' },
  { src: '/images/20241013_192321.jpg', alt: 'Вечер', permalink: 'https://www.instagram.com/ann_in_rome/' },
];
const photos = isLive ? instagramPhotos : fallbackPhotos;
