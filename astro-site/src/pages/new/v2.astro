  /* ============= ANIMATIONS ============= */
  .reveal-el {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-el.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<!-- ===================== SCRIPTS ===================== -->
<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  const heroSection = document.getElementById('hero');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Burger
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('active');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });
  menu?.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      burger?.classList.remove('active');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // WhatsApp float — visible after hero scroll
  const waFloat = document.getElementById('waFloat');
  window.addEventListener('scroll', () => {
    if (heroSection) {
      const heroBottom = heroSection.getBoundingClientRect().bottom;
      waFloat?.classList.toggle('visible', heroBottom < 0);
    } else {
      waFloat?.classList.toggle('visible', window.scrollY > 400);
    }
  });

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal-el').forEach(el => {
    observer.observe(el);
  });

  // Collapsible tour blocks
  document.querySelectorAll('.tour-card-toggle').forEach(toggle => {
    toggle.addEventListener('click', () => {
      const targetId = toggle.getAttribute('data-target');
      const target = document.getElementById(targetId);
      if (!target) return;

      const isOpen = target.classList.contains('open');

      if (isOpen) {
        target.classList.remove('open');
        toggle.classList.remove('active');
      } else {
        target.classList.add('open');
        toggle.classList.add('active');
      }
    });
  });

  // Contact form — Telegram
  const form = document.getElementById('contactForm');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = form.querySelector('[name="name"]').value;
    const contact = form.querySelector('[name="contact"]').value;
    const message = form.querySelector('[name="message"]').value;
    const text = `📩 Новая заявка с сайта anna.amalfi.day\n\n👤 Имя: ${name}\n📱 Контакт: ${contact}\n💬 Сообщение: ${message}`;
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Отправка...';
    try {
      const botToken = 'BOT_TOKEN_PLACEHOLDER';
      const chatId = 'CHAT_ID_PLACEHOLDER';
      const res = await fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text, parse_mode: 'HTML' }),
      });
      if (res.ok) {
        form.innerHTML = '<p class="form-success">Спасибо! Ваше сообщение отправлено. Я свяжусь с вами в ближайшее время!</p>';
      } else {
        throw new Error();
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Отправить';
      alert('Ошибка отправки. Пожалуйста, напишите напрямую в WhatsApp или Telegram.');
    }
  });
</script>

