<!-- ===================== STYLES ===================== -->
<style>
  /* ============= RESET & BASE ============= */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    color: #333;
    background: #FFFEF7;
    line-height: 1.7;
    overflow-x: hidden;
  }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  button { border: none; background: none; cursor: pointer; font-family: inherit; }

  /* ============= PALETTE ============= */
  :root {
    --yellow: #FFE066;
    --yellow-dark: #FFC107;
    --yellow-deep: #F9A825;
    --blue: #1565C0;
    --blue-light: #42A5F5;
    --blue-dark: #0D47A1;
    --coral: #FF7043;
    --cream: #FFFEF7;
    --cream-dark: #FFF8E1;
    --white: #FFFFFF;
    --text: #2D3748;
    --text-light: #718096;
    --radius: 20px;
    --radius-sm: 12px;
    --shadow: 0 8px 32px rgba(21, 101, 192, 0.08);
    --shadow-lifted: 0 16px 48px rgba(21, 101, 192, 0.12);
    --transition: 0.3s ease;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* ============= DECORATIVE LEMONS ============= */
  .lemon {
    position: fixed;
    width: 60px;
    height: 80px;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    background: linear-gradient(135deg, var(--yellow), var(--yellow-dark));
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .lemon::after {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 14px;
    background: #4CAF50;
    border-radius: 2px;
  }
  .lemon-1 { top: 15%; left: 3%; animation: lemonFloat 8s ease-in-out infinite; }
  .lemon-2 { top: 45%; right: 2%; width: 40px; height: 55px; animation: lemonFloat 10s ease-in-out infinite reverse; }
  .lemon-3 { top: 75%; left: 5%; width: 50px; height: 65px; animation: lemonFloat 12s ease-in-out infinite 2s; }

  @keyframes lemonFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-20px) rotate(5deg); }
    66% { transform: translateY(10px) rotate(-3deg); }
  }

  /* ============= BUTTONS ============= */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px; border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.88rem;
    letter-spacing: 0.5px;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    cursor: pointer; border: none;
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-yellow {
    background: linear-gradient(135deg, var(--yellow), var(--yellow-dark));
    color: var(--text);
    box-shadow: 0 6px 24px rgba(255, 193, 7, 0.35);
  }
  .btn-yellow:hover { box-shadow: 0 10px 36px rgba(255, 193, 7, 0.5); }
  .btn-blue {
    background: linear-gradient(135deg, var(--blue-light), var(--blue));
    color: #fff;
    box-shadow: 0 6px 24px rgba(21, 101, 192, 0.3);
  }
  .btn-blue:hover { box-shadow: 0 10px 36px rgba(21, 101, 192, 0.45); }
  .btn-white-outline {
    background: rgba(255,255,255,0.1);
    color: #fff;
    border: 2px solid rgba(255,255,255,0.4);
    backdrop-filter: blur(4px);
  }
  .btn-white-outline:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.7);
  }
  .btn-sm { padding: 10px 24px; font-size: 0.82rem; }
  .btn-full { width: 100%; justify-content: center; }

  /* ============= SECTION LABELS ============= */
  .caveat-label {
    display: block;
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    color: var(--coral);
    margin-bottom: 4px;
  }
  .caveat-label--white { color: var(--yellow); }

  .section-label {
    display: block;
    font-family: 'Caveat', cursive;
    font-size: 1.4rem;
    color: var(--coral);
    margin-bottom: 4px;
    text-align: center;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--blue-dark);
    text-align: center;
    margin-bottom: 12px;
  }
  .title-underline {
    width: 80px; height: 4px;
    background: linear-gradient(90deg, var(--yellow), var(--yellow-dark));
    border-radius: 2px;
    margin: 0 auto 48px;
  }
  .section-header { margin-bottom: 8px; }

  /* ============= NAVIGATION ============= */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(255, 254, 247, 0);
    backdrop-filter: blur(0px);
    transition: background 0.4s, backdrop-filter 0.4s, box-shadow 0.4s;
  }
  .nav.scrolled {
    background: rgba(255, 254, 247, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 2px 24px rgba(21, 101, 192, 0.08);
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 32px; height: 72px;
  }
  .nav-logo {
    font-family: 'Caveat', cursive;
    font-size: 1.6rem; font-weight: 700;
    color: #fff;
    transition: color 0.4s;
  }
  .nav.scrolled .nav-logo { color: var(--text); }
  .nav-dot { color: var(--yellow); }

  .nav-links { display: flex; gap: 4px; list-style: none; }
  .nav-links a {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600; font-size: 0.88rem;
    color: rgba(255,255,255,0.85);
    padding: 8px 16px;
    border-radius: 50px;
    transition: color var(--transition), background var(--transition);
  }
  .nav.scrolled .nav-links a { color: var(--text); }
  .nav-links a:hover {
    background: rgba(255,224,102,0.2);
    color: #fff;
  }
  .nav.scrolled .nav-links a:hover {
    background: rgba(255,224,102,0.3);
    color: var(--text);
  }

  .nav-cta {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.82rem;
    background: linear-gradient(135deg, var(--yellow), var(--yellow-dark));
    color: var(--text);
    padding: 10px 24px; border-radius: 50px;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(255,193,7,0.4); }

  .burger { display: none; flex-direction: column; gap: 5px; z-index: 1100; padding: 8px; }
  .burger span { display: block; width: 26px; height: 2.5px; background: #fff; border-radius: 2px; transition: var(--transition); }
  .nav.scrolled .burger span { background: var(--text); }
  .burger.active span { background: #fff !important; }
  .burger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5.5px); }
  .burger.active span:nth-child(2) { opacity: 0; }
  .burger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5.5px); }

  .mobile-menu {
    position: fixed; inset: 0; z-index: 1050;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.4s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }
  .mobile-menu-inner { display: flex; flex-direction: column; align-items: center; gap: 24px; }
  .mobile-link {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700;
    color: #fff;
    transition: color var(--transition);
  }
  .mobile-link:hover { color: var(--yellow); }
  .mobile-link--cta { color: var(--yellow); font-family: 'Montserrat', sans-serif; font-size: 1rem; }

  @media (max-width: 900px) {
    .nav-inner { padding: 0 20px; }
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .burger { display: flex; }
  }

  /* ============= HERO ============= */
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute; inset: 0;
  }
  .hero-bg img {
    width: 100%; height: 100%; object-fit: cover;
    animation: heroZoom 25s ease-in-out infinite alternate;
  }
  @keyframes heroZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13, 71, 161, 0.75) 0%,
      rgba(13, 71, 161, 0.5) 40%,
      rgba(13, 71, 161, 0.2) 70%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }
  .hero-inner {
    position: relative; z-index: 2;
    display: flex; align-items: center; gap: 60px;
    max-width: 1200px; margin: 0 auto;
    padding: 120px 48px 100px;
    width: 100%;
  }
  .hero-text { flex: 1; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600; font-size: 0.85rem;
    color: var(--yellow);
    margin-bottom: 20px;
    padding: 6px 16px;
    background: rgba(255, 224, 102, 0.15);
    border-radius: 50px;
    backdrop-filter: blur(4px);
  }
  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .hero-accent {
    font-family: 'Caveat', cursive;
    font-weight: 700;
    font-size: 1.15em;
    color: var(--yellow);
  }
  .hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 36px;
    max-width: 420px;
    line-height: 1.7;
  }
  .hero-buttons { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-image-frame {
    flex: 0 0 340px;
    position: relative;
  }
  .hero-image-blob {
    position: absolute;
    inset: -20px;
    background: linear-gradient(135deg, var(--yellow), var(--coral));
    border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
    opacity: 0.3;
    animation: blobMorph 8s ease-in-out infinite;
  }
  @keyframes blobMorph {
    0%, 100% { border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%; }
    25% { border-radius: 50% 50% 40% 60% / 60% 40% 50% 50%; }
    50% { border-radius: 40% 60% 50% 50% / 50% 50% 60% 40%; }
    75% { border-radius: 50% 40% 60% 50% / 40% 50% 50% 60%; }
  }
  .hero-image-frame img {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
    animation: blobMorph 8s ease-in-out infinite;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .hero-wave {
    position: absolute; bottom: -1px; left: 0; right: 0; z-index: 3;
  }
  .hero-wave svg { display: block; width: 100%; height: auto; }

  @media (max-width: 900px) {
    .hero-inner { flex-direction: column; padding: 120px 24px 100px; gap: 40px; text-align: center; }
    .hero-tagline { margin-left: auto; margin-right: auto; }
    .hero-buttons { justify-content: center; }
    .hero-image-frame { flex: none; width: 260px; }
  }
  @media (max-width: 600px) {
    .hero-image-frame { display: none; }
    .hero-text h1 { font-size: 2.4rem; }
  }

  /* ============= ABOUT ============= */
  .about {
    background: var(--cream);
    padding: 100px 0;
    position: relative;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 60px;
    align-items: center;
  }
  .about-photo {
    position: relative;
  }
  .about-frame {
    position: relative;
    z-index: 1;
    border-radius: 40% 60% 50% 50% / 50% 40% 60% 50%;
    overflow: hidden;
    box-shadow: var(--shadow-lifted);
  }
  .about-frame img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  .about-blob {
    position: absolute;
    top: -30px; left: -30px; right: -30px; bottom: -30px;
    background: linear-gradient(135deg, var(--yellow), rgba(255,224,102,0.3));
    border-radius: 60% 40% 55% 45% / 45% 55% 45% 55%;
    z-index: 0;
    animation: blobMorph 10s ease-in-out infinite;
  }
  .about-text h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--blue-dark);
    margin-bottom: 20px;
  }
  .about-text h2 em {
    font-family: 'Caveat', cursive;
    font-style: normal;
    color: var(--coral);
    font-size: 1.2em;
  }
  .about-text p {
    font-size: 1rem; color: #555;
    line-height: 1.85; margin-bottom: 14px;
  }
  .about-text strong { color: var(--blue); }
  .about-quote {
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    color: var(--blue);
    padding: 20px 24px;
    margin: 24px 0;
    background: linear-gradient(135deg, rgba(255,224,102,0.15), rgba(66,165,245,0.1));
    border-radius: var(--radius);
    border-left: 4px solid var(--yellow-dark);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-photo { max-width: 280px; margin: 0 auto; }
    .about-text { text-align: center; }
    .about-quote { text-align: center; border-left: none; border-top: 4px solid var(--yellow-dark); }
  }

  /* ============= TOURS ============= */
  .tours {
    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-dark) 100%);
    padding: 100px 0;
  }

  .tour-card {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-bottom: 32px;
    transition: box-shadow var(--transition);
  }
  .tour-card:hover { box-shadow: var(--shadow-lifted); }

  .tour-card-cover {
    position: relative;
    min-height: 360px;
    overflow: hidden;
  }
  .tour-card-cover--short { min-height: 260px; }
  .tour-card-cover img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .tour-card:hover .tour-card-cover img { transform: scale(1.03); }
  .tour-card-cover-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(0deg, rgba(13,71,161,0.85) 0%, rgba(13,71,161,0.3) 50%, transparent 100%);
  }
  .tour-card-cover-content {
    position: relative; z-index: 2;
    padding: 32px;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    height: 100%; min-height: inherit;
  }

  .tour-category {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 2px;
    color: var(--yellow);
    background: rgba(255,224,102,0.15);
    padding: 4px 14px;
    border-radius: 50px;
    margin-bottom: 10px;
    width: fit-content;
  }
  .tour-card-cover-content h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #fff;
    margin-bottom: 8px;
  }
  .tour-route {
    font-family: 'Caveat', cursive;
    font-size: 1.1rem;
    color: var(--yellow);
    margin-bottom: 8px;
  }
  .tour-meta {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; color: rgba(255,255,255,0.7);
  }
  .tour-meta-dot {
    width: 4px; height: 4px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
  }

  .tour-card-body { padding: 28px 32px; }
  .tour-brief {
    font-size: 0.95rem;
    color: var(--text-light);
    font-style: italic;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--cream-dark);
  }

  .tour-card-header-inline {
    margin-bottom: 16px;
  }
  .tour-card-header-inline h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--blue-dark);
    margin: 8px 0 4px;
  }
  .tour-card-header-inline .tour-category {
    color: var(--blue);
    background: rgba(21,101,192,0.08);
  }
  .tour-card-header-inline .tour-brief {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 4px;
  }
  .tour-card-header-inline .tour-meta {
    color: var(--text-light);
  }
  .tour-card-header-inline .tour-meta-dot {
    background: var(--text-light);
  }

  /* Toggle */
  .tour-card-toggle {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 0;
    cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--blue);
    border-top: 1px solid var(--cream-dark);
    transition: color var(--transition);
  }
  .tour-card-toggle:hover { color: var(--blue-dark); }
  .toggle-chevron { transition: transform 0.3s ease; }
  .tour-card-toggle.active .toggle-chevron { transform: rotate(180deg); }

  .tour-collapsible {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }
  .tour-collapsible.open {
    max-height: 3000px;
  }

  /* Tour features (boat) */
  .tour-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
    padding-top: 16px;
  }
  .tour-feature {
    text-align: center;
    padding: 24px 16px;
    background: var(--cream);
    border-radius: var(--radius-sm);
  }
  .tour-feature-icon {
    width: 48px; height: 48px;
    margin: 0 auto 12px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(21,101,192,0.08);
    border-radius: 50%;
  }
  .tour-feature h4 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.88rem;
    color: var(--blue-dark);
    margin-bottom: 8px;
  }
  .tour-feature p {
    font-size: 0.88rem; color: #666; line-height: 1.7;
  }

  /* Tour stops */
  .tour-stops {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
    padding-top: 16px;
  }
  .tour-stop {
    padding: 20px;
    background: var(--cream);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--yellow-dark);
  }
  .tour-stop h4 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.9rem;
    color: var(--blue-dark);
    margin-bottom: 8px;
  }
  .tour-stop p {
    font-size: 0.9rem; color: #555; line-height: 1.75;
  }

  .tour-description {
    padding-top: 16px;
    margin-bottom: 24px;
  }
  .tour-description p {
    font-size: 0.95rem; color: #555;
    line-height: 1.8; margin-bottom: 12px;
  }
  .tour-bullet-list {
    padding-left: 24px; margin-bottom: 12px;
  }
  .tour-bullet-list li {
    font-size: 0.95rem; color: #555;
    line-height: 1.75; list-style: disc;
  }

  /* Boats */
