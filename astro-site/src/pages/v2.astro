    font-size: 0.95rem; color: #555; line-height: 1.8; margin-bottom: 12px;
  }
  .tour-desc-full { margin-bottom: 24px; }

  .tour-list {
    padding-left: 20px; margin-bottom: 12px;
  }
  .tour-list li {
    font-size: 0.95rem; color: #555; line-height: 1.75; list-style: disc;
  }

  .tour-block-header { margin-bottom: 20px; }
  .tour-block-title {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.15rem; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--navy); margin-bottom: 6px; margin-top: 4px;
  }

  .tour-sub-label {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px;
    color: var(--navy); margin-bottom: 16px;
  }

  .boat-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px; margin-bottom: 20px;
  }
  .boat-card {
    background: var(--sand); border-radius: var(--radius);
    overflow: hidden; position: relative;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .boat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .boat-card--featured { border: 2px solid var(--coral); }
  .boat-badge {
    position: absolute; top: 10px; right: 10px; z-index: 2;
    background: var(--coral); color: #fff;
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    padding: 4px 12px; border-radius: 2px;
    font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px;
  }
  .boat-card-img {
    height: 160px; overflow: hidden; background: var(--white);
    display: flex; align-items: center; justify-content: center;
  }
  .boat-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .boat-card-body { padding: 16px; }
  .boat-card-body h4 {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 0.95rem; color: var(--navy); margin-bottom: 4px;
  }
  .boat-spec { font-size: 0.78rem; color: var(--text-light); display: block; margin-bottom: 6px; }
  .boat-price {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 1.15rem; color: var(--navy); margin-bottom: 6px;
  }
  .boat-note { font-size: 0.75rem; color: var(--coral); font-style: italic; margin-bottom: 8px; }
  .tour-cta-link {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.78rem;
    color: var(--coral); text-transform: uppercase; letter-spacing: 1.5px;
    display: inline-flex; gap: 4px; transition: gap var(--transition);
  }
  .tour-cta-link:hover { gap: 8px; }

  .tour-departure {
    font-size: 0.88rem; color: #666;
  }
  .tour-departure strong { color: var(--navy); }

  .tour-pricing {
    background: var(--sand); border-radius: var(--radius); padding: 24px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-top: 24px;
  }
  .tour-pricing-main { }
  .tour-price {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.4rem; color: var(--navy);
  }
  .tour-price small { font-size: 0.7rem; font-weight: 500; color: var(--text-light); }
  .tour-price-note { display: block; font-size: 0.8rem; color: var(--text-light); margin-top: 2px; }
  .tour-pickup {
    font-size: 0.82rem; color: #777; line-height: 1.6;
  }
  .tour-pickup strong { color: var(--navy); }

  .section-divider { margin: 60px 0 20px; }

  @media (max-width: 900px) {
    .boat-grid { grid-template-columns: 1fr 1fr; }
    .tour-desc-cols { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .boat-grid { grid-template-columns: 1fr; }
    .tour-cover { min-height: 260px; }
    .tour-cover--short { min-height: 200px; }
    .tour-details { padding: 24px 20px; }
    .tour-pricing { flex-direction: column; text-align: center; align-items: stretch; }
  }

  /* ============= GROUP BANNER ============= */
  .group-banner {
    background: var(--navy); padding: 80px 24px; text-align: center;
    position: relative; overflow: hidden;
  }
  .group-glow {
    position: absolute; width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,114,92,0.2), transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .group-content { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .group-content p {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    text-transform: uppercase; letter-spacing: 2px;
    color: #fff; margin-bottom: 28px; line-height: 1.5;
  }

  /* ============= GALLERY ============= */
  .gallery { background: var(--sand); padding: 100px 0 80px; }
  .filmstrip {
    overflow-x: auto; scrollbar-width: none;
    padding: 0 24px 20px;
  }
  .filmstrip::-webkit-scrollbar { display: none; }
  .filmstrip-track {
    display: flex; gap: 16px; width: max-content;
  }
  .film-item {
    flex: 0 0 320px; height: 240px; border-radius: var(--radius);
    overflow: hidden; position: relative;
  }
  .film-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .film-item:hover img { transform: scale(1.05); }
  .film-item--cta {
    background: var(--navy); display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
    flex: 0 0 200px;
  }
  .film-item--cta span {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 0.9rem; color: #fff; letter-spacing: 2px;
  }
  .film-item--cta .btn-outline {
    color: #fff; border-color: rgba(255,255,255,0.3);
  }

  @media (max-width: 768px) {
    .film-item { flex: 0 0 260px; height: 200px; }
  }

  /* ============= REVIEWS ============= */
  .reviews { background: var(--sand); padding: 100px 0; }
  .reviews-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; max-width: 900px; margin: 0 auto;
  }
  .review-card {
    background: var(--white); border-radius: var(--radius);
    padding: 12px; box-shadow: var(--shadow);
    border-top: 3px solid var(--gold);
  }
  .review-card img { width: 100%; border-radius: 2px; }

  @media (max-width: 600px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  /* ============= CONTACTS ============= */
  .contacts { background: var(--sand); padding: 80px 24px; }
  .contacts-buttons {
    display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;
  }
  .contact-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 36px; border-radius: var(--radius);
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 0.85rem;
    color: #fff; text-transform: uppercase; letter-spacing: 1.5px;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .contact-btn:hover { transform: translateY(-3px); }
  .contact-btn--wa { background: #25D366; box-shadow: 0 8px 24px rgba(37,211,102,0.3); }
  .contact-btn--tg { background: #0088cc; box-shadow: 0 8px 24px rgba(0,136,204,0.3); }
  .contact-btn--ig { background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); box-shadow: 0 8px 24px rgba(131,58,180,0.3); }

  @media (max-width: 600px) {
    .contacts-buttons { flex-direction: column; align-items: center; }
    .contact-btn { width: 100%; max-width: 300px; justify-content: center; }
  }

  /* ============= FOOTER ============= */
  .footer {
    background: var(--navy-dark); padding: 60px 24px 0;
    position: relative; overflow: hidden;
  }
  .footer-watermark {
    position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%);
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 14rem; letter-spacing: 30px;
    color: rgba(255,255,255,0.02); pointer-events: none;
    white-space: nowrap;
  }
  .footer-inner {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px;
    max-width: 1100px; margin: 0 auto 48px;
    position: relative; z-index: 1;
  }
  .footer-logo {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.6rem; color: #fff; letter-spacing: 8px; margin-bottom: 12px;
  }
  .footer-brand p { color: rgba(255,255,255,0.4); line-height: 1.7; font-size: 0.9rem; max-width: 340px; }
  .footer-col h4 {
    font-family: 'Montserrat', sans-serif; font-size: 0.7rem; font-weight: 800;
    letter-spacing: 3px; color: var(--gold); margin-bottom: 20px;
  }
  .footer-col a {
    display: block; color: rgba(255,255,255,0.4);
    font-size: 0.9rem; margin-bottom: 12px;
    transition: color var(--transition);
  }
  .footer-col a:hover { color: #fff; }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 24px 0; text-align: center;
    color: rgba(255,255,255,0.2); font-size: 0.82rem;
    position: relative; z-index: 1;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-watermark { font-size: 6rem; letter-spacing: 10px; }
  }

  /* ============= WA FLOAT ============= */
  .wa-float {
    position: fixed; bottom: 28px; right: 28px; z-index: 900;
    width: 56px; height: 56px; border-radius: var(--radius);
    background: #25D366; display: flex; align-items: center; justify-content: center;
    color: #fff; box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform var(--transition), box-shadow var(--transition);
    opacity: 0; pointer-events: none;
  }
  .wa-float.visible { opacity: 1; pointer-events: all; }
  .wa-float:hover { transform: scale(1.1); box-shadow: 0 10px 36px rgba(37,211,102,0.5); }

  /* ============= ANIMATIONS ============= */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Burger
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('active');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });
  menu?.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      burger?.classList.remove('active');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // WhatsApp float
  const waFloat = document.getElementById('waFloat');
  window.addEventListener('scroll', () => {
    waFloat?.classList.toggle('visible', window.scrollY > 400);
  });

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.about-inner, .tour-block, .section-divider, .group-content, .filmstrip-track, .reviews-grid, .contacts-buttons').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>

</body>
</html>
