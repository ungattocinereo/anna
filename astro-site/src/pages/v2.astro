<style>
  /* ============= RESET & BASE ============= */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    color: #333;
    background: #F5F0E8;
    line-height: 1.6;
    overflow-x: hidden;
  }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  button { border: none; background: none; cursor: pointer; font-family: inherit; }

  /* ============= PALETTE ============= */
  :root {
    --navy: #1A365D;
    --navy-dark: #0f2240;
    --coral: #E8725C;
    --gold: #D4A853;
    --sand: #F5F0E8;
    --sand-dark: #E8E0D0;
    --white: #FFFFFF;
    --text: #333;
    --text-light: #888;
    --radius: 4px;
    --shadow: 0 4px 24px rgba(26,54,93,0.08);
    --transition: 0.3s ease;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* ============= BUTTONS ============= */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px; border-radius: var(--radius);
    font-family: 'Montserrat', sans-serif;
    font-weight: 800; font-size: 0.82rem;
    text-transform: uppercase; letter-spacing: 2px;
    transition: transform var(--transition), box-shadow var(--transition);
    cursor: pointer;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary {
    background: var(--coral); color: #fff;
    box-shadow: 0 6px 20px rgba(232,114,92,0.3);
  }
  .btn-primary:hover { box-shadow: 0 10px 28px rgba(232,114,92,0.45); }
  .btn-outline {
    background: transparent; color: #fff;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
  .btn-sm { padding: 10px 22px; font-size: 0.75rem; letter-spacing: 1.5px; }

  /* ============= SECTION LABELS ============= */
  .section-label {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-weight: 800; font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 4px;
    color: var(--coral); margin-bottom: 8px;
  }
  .section-label--center { text-align: center; }
  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900; font-size: clamp(1.8rem, 4vw, 2.6rem);
    text-transform: uppercase; letter-spacing: 3px;
    color: var(--navy); text-align: center; margin-bottom: 16px;
  }
  .coral-rule {
    width: 60px; height: 3px; background: var(--coral);
    margin: 0 auto 48px;
  }

  /* ============= NAV ============= */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 0 48px; height: 72px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(26,54,93,0.0);
    backdrop-filter: blur(0px);
    transition: background 0.5s, backdrop-filter 0.5s, box-shadow 0.5s;
  }
  .nav.scrolled {
    background: rgba(245,240,232,0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 1px 20px rgba(26,54,93,0.08);
  }
  .nav-logo {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.4rem; letter-spacing: 8px; color: #fff;
    transition: color 0.5s;
  }
  .nav.scrolled .nav-logo { color: var(--navy); }
  .nav-links { display: flex; gap: 4px; align-items: center; }
  .nav-links a {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.75rem;
    color: rgba(255,255,255,0.8); text-transform: uppercase; letter-spacing: 1.5px;
    padding: 8px 14px; position: relative;
    transition: color var(--transition);
  }
  .nav.scrolled .nav-links a { color: var(--navy); }
  .nav-links a::after {
    content: ''; position: absolute; bottom: 4px; left: 14px; right: 14px;
    height: 2px; background: var(--coral);
    transform: scaleX(0); transform-origin: center;
    transition: transform var(--transition);
  }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-cta {
    background: var(--coral) !important; color: #fff !important;
    padding: 10px 24px !important; border-radius: var(--radius) !important;
    font-weight: 800 !important;
  }
  .nav-cta::after { display: none !important; }
  .nav-cta:hover { box-shadow: 0 4px 16px rgba(232,114,92,0.3); }

  .burger { display: none; flex-direction: column; gap: 5px; z-index: 1100; padding: 8px; }
  .burger span { display: block; width: 26px; height: 2.5px; background: #fff; border-radius: 1px; transition: var(--transition); }
  .nav.scrolled .burger span { background: var(--navy); }
  .burger.active span { background: #fff !important; }
  .burger.active span:nth-child(1) { transform: rotate(45deg) translate(5px,5.5px); }
  .burger.active span:nth-child(2) { opacity: 0; }
  .burger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5.5px); }

  .mobile-menu {
    position: fixed; inset: 0; z-index: 1050;
    background: linear-gradient(135deg, var(--navy), var(--navy-dark));
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24px;
    opacity: 0; pointer-events: none; transition: opacity 0.4s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }
  .mobile-link {
    font-family: 'Montserrat', sans-serif; font-size: 1.3rem; font-weight: 800;
    color: #fff; text-transform: uppercase; letter-spacing: 4px;
  }
  .mobile-link:hover { color: var(--coral); }
  .mobile-link--cta { color: var(--coral); }

  @media (max-width: 900px) {
    .nav { padding: 0 20px; }
    .nav-links { display: none; }
    .burger { display: flex; }
  }

  /* ============= HERO ============= */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
  }
  .hero-bg img {
    width: 100%; height: 100%; object-fit: cover;
    animation: heroZoom 25s ease-in-out infinite alternate;
  }
  @keyframes heroZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(0deg, rgba(15,34,64,0.85) 0%, rgba(15,34,64,0.3) 50%, rgba(15,34,64,0.1) 100%);
  }
  .hero-content {
    position: relative; z-index: 2;
    padding: 0 48px 100px; max-width: 800px;
  }
  .hero-label {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 4px; color: var(--gold);
    margin-bottom: 20px;
  }
  .hero-content h1 {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: #fff; line-height: 1.05; letter-spacing: 4px;
    margin-bottom: 20px;
  }
  .hero-sub {
    font-family: 'Playfair Display', serif; font-style: italic;
    font-size: 1.2rem; color: rgba(255,255,255,0.7);
    margin-bottom: 40px; max-width: 440px;
  }
  .hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; }

  .hero-scroll {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    z-index: 2;
  }
  .hero-scroll span {
    display: block; width: 2px; height: 40px;
    background: rgba(255,255,255,0.4);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero-content { padding: 0 24px 80px; }
    .hero-content h1 { font-size: 2.6rem; letter-spacing: 2px; }
  }

  /* ============= ABOUT ============= */
  .about {
    position: relative; background: var(--sand); padding: 100px 0; overflow: hidden;
  }
  .diagonal-pattern {
    position: absolute; top: 0; right: 0; bottom: 0; width: 40%;
    background: repeating-linear-gradient(
      -45deg, transparent, transparent 20px,
      rgba(26,54,93,0.03) 20px, rgba(26,54,93,0.03) 21px
    );
    pointer-events: none;
  }
  .about-inner {
    display: flex; gap: 60px; align-items: center;
    max-width: 1100px; margin: 0 auto; padding: 0 24px;
    position: relative; z-index: 1;
  }
  .about-photo {
    flex: 0 0 35%; max-width: 380px;
  }
  .about-photo img {
    width: 100%; aspect-ratio: 3/4; object-fit: cover;
    border-radius: 2px;
    box-shadow: 0 20px 60px rgba(26,54,93,0.15);
  }
  .about-text { flex: 1; }
  .about-text h2 {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 2rem; text-transform: uppercase; letter-spacing: 2px;
    color: var(--navy); margin-bottom: 8px;
  }
  .about-text h2 em {
    font-family: 'Playfair Display', serif; font-style: italic;
    text-transform: none; letter-spacing: 0; font-weight: 700;
  }
  .about-line { width: 40px; height: 3px; background: var(--coral); margin-bottom: 24px; }
  .about-text p {
    font-size: 1rem; color: #555; line-height: 1.85; margin-bottom: 12px;
  }
  .about-text strong { color: var(--coral); }
  .about-text em { color: var(--navy); font-weight: 600; }

  @media (max-width: 768px) {
    .about-inner { flex-direction: column; gap: 40px; }
    .about-photo { flex: none; width: 260px; margin: 0 auto; }
    .about-text { text-align: center; }
    .about-line { margin-left: auto; margin-right: auto; }
    .diagonal-pattern { display: none; }
  }

  /* ============= TOURS (BENTO) ============= */
  .tours { background: var(--sand); padding: 100px 0; }

  .bento {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .bento-card {
    position: relative; border-radius: var(--radius);
    overflow: hidden; background: var(--navy);
  }
  .bento-card--hero { grid-column: 1 / -1; min-height: 420px; }
  .bento-card--img { min-height: 360px; }
  .bento-card--exp {
    grid-column: 1 / -1; background: var(--white);
    padding: 32px; display: flex; flex-direction: column; gap: 12px;
  }

  .bento-bg { position: absolute; inset: 0; }
  .bento-bg img { width: 100%; height: 100%; object-fit: cover; }
  .bento-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(0deg, rgba(15,34,64,0.9) 0%, rgba(15,34,64,0.3) 60%, transparent 100%);
  }
  .bento-body {
    position: relative; z-index: 2; padding: 32px;
    display: flex; flex-direction: column; justify-content: flex-end;
    height: 100%;
  }
  .bento-tag {
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 0.65rem;
    text-transform: uppercase; letter-spacing: 3px; color: var(--gold);
    margin-bottom: 8px;
  }
  .bento-card--exp .bento-tag { color: var(--coral); margin-bottom: 16px; }
  .bento-body h3 {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.6rem; text-transform: uppercase; letter-spacing: 2px;
    color: #fff; margin-bottom: 8px;
  }
  .bento-body p { font-size: 0.9rem; color: rgba(255,255,255,0.7); margin-bottom: 8px; }
  .bento-meta {
    font-size: 0.8rem; color: rgba(255,255,255,0.5);
    font-weight: 500; margin-bottom: 16px;
  }
  .bento-link {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.8rem;
    color: var(--coral); text-transform: uppercase; letter-spacing: 1.5px;
    transition: gap var(--transition); display: inline-flex; gap: 4px;
  }
  .bento-link:hover { gap: 8px; }

  .bento-boats {
    display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;
  }
  .bento-boat {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.08); border-radius: var(--radius);
    padding: 8px 14px 8px 8px;
  }
  .bento-boat img { width: 48px; height: 32px; object-fit: contain; border-radius: 2px; }
  .bento-boat span { font-size: 0.8rem; color: rgba(255,255,255,0.8); }
  .bento-boat strong { color: #fff; }
  .bento-boat em {
    font-size: 0.65rem; color: var(--coral);
    text-transform: uppercase; letter-spacing: 1px;
  }

  /* Experience bars */
  .exp-bar {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px; background: var(--sand); border-radius: var(--radius);
    transition: background var(--transition);
  }
  .exp-bar:hover { background: var(--sand-dark); }
  .exp-bar-img {
    flex: 0 0 60px; height: 44px; border-radius: 2px; overflow: hidden;
  }
  .exp-bar-img img { width: 100%; height: 100%; object-fit: cover; }
  .exp-bar-text { flex: 1; }
  .exp-bar-text h4 {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 0.85rem; color: var(--navy); margin-bottom: 2px;
  }
  .exp-bar-text span { font-size: 0.78rem; color: var(--text-light); }
  .exp-bar-cta {
    flex: 0 0 40px; width: 40px; height: 40px;
    border-radius: 50%; background: var(--coral); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 700;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .exp-bar-cta:hover { transform: scale(1.1); box-shadow: 0 4px 16px rgba(232,114,92,0.3); }

  @media (max-width: 768px) {
    .bento { grid-template-columns: 1fr; }
    .bento-card--hero { min-height: 500px; }
    .bento-boats { flex-direction: column; }
  }

  /* ============= GROUP BANNER ============= */
  .group-banner {
    background: var(--navy); padding: 80px 24px; text-align: center;
    position: relative; overflow: hidden;
  }
  .group-glow {
    position: absolute; width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,114,92,0.2), transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .group-content { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .group-content p {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    text-transform: uppercase; letter-spacing: 2px;
    color: #fff; margin-bottom: 28px; line-height: 1.5;
  }

  /* ============= GALLERY ============= */
  .gallery { background: var(--sand); padding: 100px 0 80px; }
  .filmstrip {
    overflow-x: auto; scrollbar-width: none;
    padding: 0 24px 20px;
  }
  .filmstrip::-webkit-scrollbar { display: none; }
  .filmstrip-track {
    display: flex; gap: 16px; width: max-content;
  }
  .film-item {
    flex: 0 0 320px; height: 240px; border-radius: var(--radius);
    overflow: hidden; position: relative;
  }
  .film-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .film-item:hover img { transform: scale(1.05); }
  .film-item--cta {
    background: var(--navy); display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
    flex: 0 0 200px;
  }
  .film-item--cta span {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 0.9rem; color: #fff; letter-spacing: 2px;
  }
  .film-item--cta .btn-outline {
    color: #fff; border-color: rgba(255,255,255,0.3);
  }

  @media (max-width: 768px) {
    .film-item { flex: 0 0 260px; height: 200px; }
  }

  /* ============= REVIEWS ============= */
  .reviews { background: var(--sand); padding: 100px 0; }
  .reviews-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; max-width: 900px; margin: 0 auto;
  }
  .review-card {
    background: var(--white); border-radius: var(--radius);
    padding: 12px; box-shadow: var(--shadow);
    border-top: 3px solid var(--gold);
  }
  .review-card img { width: 100%; border-radius: 2px; }

  @media (max-width: 600px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  /* ============= CONTACTS ============= */
  .contacts { background: var(--sand); padding: 80px 24px; }
  .contacts-buttons {
    display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;
  }
  .contact-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 36px; border-radius: var(--radius);
    font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 0.85rem;
    color: #fff; text-transform: uppercase; letter-spacing: 1.5px;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .contact-btn:hover { transform: translateY(-3px); }
  .contact-btn--wa { background: #25D366; box-shadow: 0 8px 24px rgba(37,211,102,0.3); }
  .contact-btn--tg { background: #0088cc; box-shadow: 0 8px 24px rgba(0,136,204,0.3); }
  .contact-btn--ig { background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); box-shadow: 0 8px 24px rgba(131,58,180,0.3); }

  @media (max-width: 600px) {
    .contacts-buttons { flex-direction: column; align-items: center; }
    .contact-btn { width: 100%; max-width: 300px; justify-content: center; }
  }

  /* ============= FOOTER ============= */
  .footer {
    background: var(--navy-dark); padding: 60px 24px 0;
    position: relative; overflow: hidden;
  }
  .footer-watermark {
    position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%);
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 14rem; letter-spacing: 30px;
    color: rgba(255,255,255,0.02); pointer-events: none;
    white-space: nowrap;
  }
  .footer-inner {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px;
    max-width: 1100px; margin: 0 auto 48px;
    position: relative; z-index: 1;
  }
  .footer-logo {
    font-family: 'Montserrat', sans-serif; font-weight: 900;
    font-size: 1.6rem; color: #fff; letter-spacing: 8px; margin-bottom: 12px;
  }
  .footer-brand p { color: rgba(255,255,255,0.4); line-height: 1.7; font-size: 0.9rem; max-width: 340px; }
  .footer-col h4 {
    font-family: 'Montserrat', sans-serif; font-size: 0.7rem; font-weight: 800;
    letter-spacing: 3px; color: var(--gold); margin-bottom: 20px;
  }
  .footer-col a {
    display: block; color: rgba(255,255,255,0.4);
    font-size: 0.9rem; margin-bottom: 12px;
    transition: color var(--transition);
  }
  .footer-col a:hover { color: #fff; }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 24px 0; text-align: center;
    color: rgba(255,255,255,0.2); font-size: 0.82rem;
    position: relative; z-index: 1;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-watermark { font-size: 6rem; letter-spacing: 10px; }
  }

  /* ============= WA FLOAT ============= */
  .wa-float {
    position: fixed; bottom: 28px; right: 28px; z-index: 900;
    width: 56px; height: 56px; border-radius: var(--radius);
    background: #25D366; display: flex; align-items: center; justify-content: center;
    color: #fff; box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform var(--transition), box-shadow var(--transition);
    opacity: 0; pointer-events: none;
  }
  .wa-float.visible { opacity: 1; pointer-events: all; }
  .wa-float:hover { transform: scale(1.1); box-shadow: 0 10px 36px rgba(37,211,102,0.5); }

  /* ============= ANIMATIONS ============= */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Burger
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('active');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });
  menu?.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      burger?.classList.remove('active');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // WhatsApp float
  const waFloat = document.getElementById('waFloat');
  window.addEventListener('scroll', () => {
    waFloat?.classList.toggle('visible', window.scrollY > 400);
  });

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.about-inner, .bento, .group-content, .filmstrip-track, .reviews-grid, .contacts-buttons').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>

</body>
</html>
