<style>
  /* ============= RESET & BASE ============= */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    color: #3a3a3a;
    background: #FFFDF0;
    line-height: 1.6;
    overflow-x: hidden;
  }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }
  button { border: none; background: none; cursor: pointer; font-family: inherit; }

  /* ============= PALETTE ============= */
  :root {
    --lemon: #FFE066;
    --olive: #4A6741;
    --terracotta: #C75B39;
    --cream: #FFFDF0;
    --cream-dark: #F5EDD6;
    --text: #3a3a3a;
    --text-light: #777;
    --radius: 20px;
    --radius-lg: 24px;
    --shadow: 0 8px 32px rgba(74,103,65,0.1);
    --transition: 0.3s ease;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* ============= BUTTONS ============= */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700; font-size: 0.9rem;
    transition: transform var(--transition), box-shadow var(--transition);
    cursor: pointer;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary {
    background: var(--terracotta); color: #fff;
    box-shadow: 0 6px 20px rgba(199,91,57,0.3);
  }
  .btn-primary:hover { box-shadow: 0 10px 28px rgba(199,91,57,0.45); }
  .btn-outline {
    background: transparent; color: var(--olive);
    border: 2px solid var(--olive);
  }
  .btn-outline:hover { background: var(--olive); color: #fff; }
  .btn-sm { padding: 10px 22px; font-size: 0.82rem; }

  /* ============= NAV ============= */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 0 48px; height: 72px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(255,253,240,0.7);
    backdrop-filter: blur(16px) saturate(160%);
    transition: background 0.4s, box-shadow 0.4s;
  }
  .nav.scrolled {
    background: rgba(255,253,240,0.95);
    box-shadow: 0 2px 20px rgba(74,103,65,0.08);
  }
  .nav-logo { display: flex; align-items: center; gap: 4px; }
  .nav-logo-text {
    font-family: 'Playfair Display', serif; font-style: italic;
    font-weight: 700; font-size: 1.6rem; color: var(--olive); letter-spacing: 2px;
  }
  .nav-logo-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--lemon); margin-top: 8px;
  }
  .nav-links { display: flex; gap: 6px; align-items: center; }
  .nav-links a {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600; font-size: 0.8rem;
    color: var(--olive); text-transform: uppercase; letter-spacing: 1.2px;
    padding: 8px 14px; border-radius: 12px;
    transition: color var(--transition);
  }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-cta {
    background: var(--terracotta) !important; color: #fff !important;
    padding: 10px 24px !important; border-radius: 50px !important;
    font-weight: 700 !important;
  }
  .nav-cta:hover { box-shadow: 0 6px 20px rgba(199,91,57,0.3); }

  .burger { display: none; flex-direction: column; gap: 5px; z-index: 1100; padding: 8px; }
  .burger span { display: block; width: 26px; height: 2.5px; background: var(--olive); border-radius: 2px; transition: var(--transition); }
  .burger.active span:nth-child(1) { transform: rotate(45deg) translate(5px,5.5px); background: #fff; }
  .burger.active span:nth-child(2) { opacity: 0; }
  .burger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5.5px); background: #fff; }

  .mobile-menu {
    position: fixed; inset: 0; z-index: 1050;
    background: linear-gradient(135deg, var(--olive), #2d3d27);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24px;
    opacity: 0; pointer-events: none; transition: opacity 0.4s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: all; }
  .mobile-link {
    font-family: 'Montserrat', sans-serif; font-size: 1.4rem; font-weight: 700;
    color: #fff; text-transform: uppercase; letter-spacing: 2px;
  }
  .mobile-link:hover { color: var(--lemon); }
  .mobile-link--cta { color: var(--lemon); }

  @media (max-width: 900px) {
    .nav { padding: 0 20px; }
    .nav-links { display: none; }
    .burger { display: flex; }
  }

  /* ============= HERO ============= */
  .hero {
    position: relative; min-height: 100vh;
    background: linear-gradient(160deg, var(--cream) 50%, #f0e8c8 100%);
    display: flex; align-items: center;
    overflow: hidden;
  }
  .hero-circles { position: absolute; inset: 0; pointer-events: none; }
  .hero-circle {
    position: absolute; border-radius: 50%;
    background: var(--lemon); opacity: 0.25;
  }
  .hero-circle--1 { width: 400px; height: 400px; top: -60px; right: 5%; }
  .hero-circle--2 { width: 200px; height: 200px; bottom: 15%; right: 25%; opacity: 0.15; }
  .hero-circle--3 { width: 120px; height: 120px; top: 40%; right: 42%; opacity: 0.2; }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1100px; margin: 0 auto;
    padding: 140px 48px 100px;
    display: flex; align-items: center; gap: 60px; width: 100%;
  }
  .hero-text { flex: 1; }
  .hero-geo {
    display: inline-block;
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 2.5px; color: var(--olive);
    margin-bottom: 20px; padding: 6px 16px;
    background: #fff; border-radius: 50px;
    box-shadow: 0 2px 12px rgba(74,103,65,0.08);
  }
  .hero-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-weight: 900; color: var(--olive);
    line-height: 1.1; margin-bottom: 16px;
  }
  .hero-tagline {
    font-size: 1.1rem; color: var(--text-light);
    line-height: 1.7; margin-bottom: 36px; max-width: 380px;
  }
  .hero-buttons { display: flex; gap: 14px; flex-wrap: wrap; }

  .hero-photo {
    flex: 0 0 440px; position: relative;
  }
  .hero-photo img {
    width: 100%; border-radius: var(--radius-lg);
    transform: rotate(2deg);
    box-shadow: 0 20px 60px rgba(74,103,65,0.2);
    transition: transform 0.6s ease;
  }
  .hero-photo:hover img { transform: rotate(0deg) scale(1.02); }

  .wave-divider {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
    line-height: 0;
  }
  .wave-divider svg { width: 100%; height: 80px; }
  .wave-divider--top { position: absolute; top: 0; bottom: auto; }

  @media (max-width: 900px) {
    .hero-inner { flex-direction: column; padding: 120px 24px 80px; gap: 40px; text-align: center; }
    .hero-photo { flex: none; width: 90%; max-width: 400px; }
    .hero-buttons { justify-content: center; }
    .hero-tagline { margin-left: auto; margin-right: auto; }
    .hero-geo { margin-left: auto; margin-right: auto; }
    .hero-circle--1 { width: 250px; height: 250px; top: 40%; right: -10%; }
    .hero-circle--2 { display: none; }
    .hero-circle--3 { display: none; }
  }

  /* ============= ABOUT ============= */
  .about {
    background: var(--cream); padding: 100px 0;
  }
  .about-grid {
    display: flex; gap: 60px; align-items: center;
    max-width: 960px; margin: 0 auto;
  }
  .about-photo-wrap { flex: 0 0 280px; }
  .about-polaroid {
    background: #fff; padding: 16px 16px 40px; border-radius: 4px;
    box-shadow: 0 12px 40px rgba(74,103,65,0.12);
    transform: rotate(-3deg);
    transition: transform 0.5s ease;
    position: relative;
  }
  .about-polaroid:hover { transform: rotate(0deg); }
  .about-polaroid img {
    width: 100%; border-radius: 2px; aspect-ratio: 3/4; object-fit: cover;
  }
  .about-polaroid::before {
    content: ''; position: absolute; top: -6px; left: 50%; transform: translateX(-50%);
    width: 50px; height: 18px; background: rgba(255,224,102,0.6); border-radius: 2px;
  }
  .about-polaroid-label {
    display: block; text-align: center; margin-top: 10px;
    font-family: 'Playfair Display', serif; font-style: italic;
    font-size: 1.1rem; color: var(--olive);
  }
  .about-text { flex: 1; }
  .about-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 700; color: var(--olive); margin-bottom: 20px;
  }
  .about-text p {
    font-size: 1rem; color: #555; line-height: 1.8; margin-bottom: 12px;
  }
  .about-text strong { color: var(--terracotta); }
  .about-text em { color: var(--olive); font-weight: 600; }

  @media (max-width: 768px) {
    .about-grid { flex-direction: column; gap: 40px; text-align: center; }
    .about-photo-wrap { flex: none; width: 220px; margin: 0 auto; }
  }

  /* ============= TOURS ============= */
  .tours {
    background: var(--cream-dark); padding: 100px 0 80px; position: relative;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700; color: var(--olive); text-align: center; margin-bottom: 12px;
  }
  .section-title--light { color: #fff; }
  .section-subtitle {
    text-align: center; color: var(--text-light); font-size: 0.95rem; margin-bottom: 40px;
  }
  .section-subtitle--light { color: rgba(255,255,255,0.55); }

  .tour-tabs {
    display: flex; justify-content: center; gap: 8px; margin-bottom: 40px; flex-wrap: wrap;
  }
  .tour-tab {
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.85rem;
    padding: 12px 28px; border-radius: 50px;
    background: #fff; color: var(--olive);
    border: 2px solid rgba(74,103,65,0.15);
    transition: all var(--transition);
  }
  .tour-tab:hover { border-color: var(--olive); }
  .tour-tab.active {
    background: var(--olive); color: #fff; border-color: var(--olive);
  }
  .tab-content { display: none; }
  .tab-content.active { display: block; animation: fadeIn 0.4s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .tour-intro { text-align: center; margin-bottom: 32px; }
  .tour-intro h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700; color: var(--olive); margin-bottom: 8px;
  }
  .tour-route-line {
    font-weight: 700; color: var(--terracotta); font-size: 0.9rem; margin-bottom: 8px;
  }
  .tour-meta {
    font-size: 0.85rem; color: var(--text-light); font-weight: 500; margin-bottom: 16px;
  }

  .tour-desc-block {
    max-width: 720px; margin: 0 auto 32px; background: #fff;
    border-radius: var(--radius); padding: 28px 32px;
    box-shadow: var(--shadow);
  }
  .tour-desc-block h4 {
    font-size: 1rem; font-weight: 700; color: var(--olive);
    margin-top: 16px; margin-bottom: 6px;
  }
  .tour-desc-block h4:first-child { margin-top: 0; }
  .tour-desc-block p { font-size: 0.95rem; color: #555; line-height: 1.75; }

  .boat-heading {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; font-weight: 700; color: var(--olive);
    text-align: center; margin-bottom: 20px;
  }
  .boat-scroll {
    display: flex; gap: 20px; overflow-x: auto;
    padding: 8px 4px 20px; scrollbar-width: none;
  }
  .boat-scroll::-webkit-scrollbar { display: none; }
  .boat-card {
    flex: 0 0 280px; background: #fff; border-radius: var(--radius);
    overflow: hidden; box-shadow: var(--shadow);
    transition: transform var(--transition); position: relative;
  }
  .boat-card:hover { transform: translateY(-6px); }
  .boat-card--featured { border: 2px solid var(--terracotta); }
  .boat-badge {
    position: absolute; top: 12px; right: 12px; z-index: 2;
    background: var(--terracotta); color: #fff;
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    padding: 4px 12px; border-radius: 50px;
    font-size: 0.68rem; text-transform: uppercase; letter-spacing: 1px;
  }
  .boat-card img {
    width: 100%; height: 180px; object-fit: cover;
  }
  .boat-body { padding: 16px 20px 20px; }
  .boat-body h4 { font-size: 1rem; font-weight: 800; color: var(--olive); margin-bottom: 4px; }
  .boat-spec { font-size: 0.8rem; color: var(--text-light); }
  .boat-price {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 1.2rem; color: var(--olive); margin: 8px 0;
  }
  .boat-note { font-size: 0.78rem; color: var(--terracotta); font-style: italic; margin-bottom: 8px; }
  .boat-cta {
    font-weight: 700; color: var(--terracotta); font-size: 0.82rem;
    text-transform: uppercase; letter-spacing: 1px;
    transition: gap var(--transition); display: inline-flex; align-items: center; gap: 4px;
  }
  .boat-cta:hover { gap: 8px; }
  .tour-departure {
    font-size: 0.9rem; color: #666; margin-top: 20px; text-align: center;
  }
  .tour-departure strong { color: var(--olive); }

  /* Cabrio tab */
  .cabrio-card {
    display: flex; gap: 32px; background: #fff;
    border-radius: var(--radius); overflow: hidden;
    box-shadow: var(--shadow); margin-bottom: 24px;
    max-width: 900px; margin-left: auto; margin-right: auto;
  }
  .cabrio-img { flex: 0 0 40%; min-height: 300px; }
  .cabrio-img img { width: 100%; height: 100%; object-fit: cover; }
  .cabrio-text { flex: 1; padding: 28px 28px 28px 0; }
  .cabrio-text h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; font-weight: 700; color: var(--olive); margin-bottom: 8px;
  }
  .cabrio-text p { font-size: 0.92rem; color: #555; line-height: 1.75; margin-bottom: 12px; }
  .cabrio-price-row {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; margin-bottom: 12px;
    padding: 16px 20px; background: var(--cream); border-radius: 12px;
  }
  .cabrio-price {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 1.4rem; color: var(--olive);
  }
  .cabrio-price-note { font-size: 0.8rem; color: var(--text-light); display: block; }
  .pickup-note { font-size: 0.82rem; color: #888; }
  .pickup-note strong { color: var(--olive); }

  @media (max-width: 768px) {
    .cabrio-card { flex-direction: column; }
    .cabrio-img { min-height: 220px; }
    .cabrio-text { padding: 20px; }
  }

  /* Experiences tab */
  .exp-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    max-width: 800px; margin: 0 auto;
  }
  .exp-card {
    background: #fff; border-radius: var(--radius); padding: 28px;
    box-shadow: var(--shadow);
  }
  .exp-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; font-weight: 700; color: var(--olive); margin-bottom: 6px;
  }
  .exp-card p { font-size: 0.9rem; color: #555; line-height: 1.7; margin-bottom: 12px; }
  .exp-card-photo {
    margin: -28px -28px 16px; border-radius: var(--radius) var(--radius) 0 0; overflow: hidden; height: 180px;
  }
  .exp-card-photo img { width: 100%; height: 100%; object-fit: cover; }
  .exp-price {
    font-family: 'Montserrat', sans-serif; font-weight: 800;
    font-size: 1.2rem; color: var(--olive); margin-bottom: 4px;
  }
  .exp-price small { font-size: 0.7rem; font-weight: 500; color: var(--text-light); }
  .exp-note { font-size: 0.78rem; color: var(--text-light); display: block; margin-bottom: 12px; }

  @media (max-width: 600px) {
    .exp-grid { grid-template-columns: 1fr; }
  }

  /* ============= GROUP BANNER ============= */
  .group-banner {
    background: var(--cream); padding: 80px 24px; text-align: center;
    position: relative; overflow: hidden;
  }
  .group-blob {
    position: absolute; width: 400px; height: 400px;
    border-radius: 50%; background: var(--lemon); opacity: 0.15;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    filter: blur(40px);
  }
  .group-content { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .group-content p {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 700; color: var(--olive); margin-bottom: 24px; line-height: 1.5;
  }

  /* ============= GALLERY ============= */
  .gallery {
    background: var(--cream); padding: 100px 0;
  }
  .masonry {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 180px;
    gap: 12px; max-width: 1060px; margin: 0 auto 32px;
  }
  .masonry-item {
    border-radius: var(--radius); overflow: hidden; position: relative;
    transform: rotate(-1deg);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .masonry-item:nth-child(2) { transform: rotate(1.5deg); }
  .masonry-item:nth-child(3) { transform: rotate(-0.5deg); }
  .masonry-item:nth-child(5) { transform: rotate(2deg); }
  .masonry-item:nth-child(6) { transform: rotate(-1.5deg); }
  .masonry-item:nth-child(8) { transform: rotate(1deg); }
  .masonry-item:hover { transform: rotate(0deg) scale(1.03); box-shadow: 0 12px 40px rgba(74,103,65,0.2); z-index: 2; }
  .masonry-item--tall { grid-row: span 2; }
  .masonry-item img { width: 100%; height: 100%; object-fit: cover; }
  .insta-handle { text-align: center; }
  .insta-handle a {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 1rem;
    color: var(--olive); padding: 12px 28px; border-radius: 50px;
    border: 2px solid rgba(74,103,65,0.15);
    transition: all var(--transition);
  }
  .insta-handle a:hover { color: var(--terracotta); border-color: var(--terracotta); }

  @media (max-width: 768px) {
    .masonry { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 160px; }
  }

  /* ============= REVIEWS ============= */
  .reviews {
    background: var(--olive); padding: 100px 0; overflow: hidden;
  }
  .reviews-carousel {
    display: flex; align-items: center; gap: 16px;
    max-width: 1100px; margin: 0 auto;
  }
  .rev-arrow {
    flex: 0 0 44px; width: 44px; height: 44px;
    border-radius: 50%; border: 2px solid rgba(255,255,255,0.2);
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; transition: all var(--transition);
  }
  .rev-arrow:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }
  .reviews-track-wrap { flex: 1; overflow: hidden; }
  .reviews-track {
    display: flex; gap: 28px; overflow-x: auto;
    scroll-snap-type: x mandatory; scrollbar-width: none; padding: 20px 8px;
  }
  .reviews-track::-webkit-scrollbar { display: none; }
  .rev-polaroid {
    flex: 0 0 400px; background: #fff; border-radius: 4px;
    padding: 14px 14px 24px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
    position: relative; scroll-snap-align: start;
    transform: rotate(-1deg); transition: transform 0.4s ease;
  }
  .rev-polaroid:nth-child(2) { transform: rotate(1.5deg); }
  .rev-polaroid:nth-child(3) { transform: rotate(-0.5deg); }
  .rev-polaroid:nth-child(4) { transform: rotate(2deg); }
  .rev-polaroid:hover { transform: rotate(0deg) scale(1.02); }
  .rev-tape {
    position: absolute; top: -8px; left: 50%; transform: translateX(-50%) rotate(2deg);
    width: 60px; height: 20px; background: rgba(255,224,102,0.6); border-radius: 2px;
  }
  .rev-polaroid img { width: 100%; border-radius: 2px; }

  @media (max-width: 768px) {
    .rev-arrow { display: none; }
    .rev-polaroid { flex: 0 0 300px; }
  }

  /* ============= CONTACTS ============= */
  .contacts { background: var(--cream); padding: 80px 24px; }
  .contacts-buttons {
    display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;
  }
  .contact-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 36px; border-radius: 50px;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.95rem;
    color: #fff; transition: transform var(--transition), box-shadow var(--transition);
  }
  .contact-btn:hover { transform: translateY(-3px); }
  .contact-btn--wa { background: #25D366; box-shadow: 0 8px 24px rgba(37,211,102,0.3); }
  .contact-btn--tg { background: #0088cc; box-shadow: 0 8px 24px rgba(0,136,204,0.3); }
  .contact-btn--ig { background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); box-shadow: 0 8px 24px rgba(131,58,180,0.3); }

  @media (max-width: 600px) {
    .contacts-buttons { flex-direction: column; align-items: center; }
    .contact-btn { width: 100%; max-width: 300px; justify-content: center; }
  }

  /* ============= FOOTER ============= */
  .footer { background: var(--olive); padding: 60px 24px 0; }
  .footer-inner {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px;
    max-width: 1100px; margin: 0 auto 48px;
  }
  .footer-logo {
    font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700;
    color: var(--cream); letter-spacing: 2px; margin-bottom: 12px;
    display: inline-flex; align-items: flex-start;
  }
  .footer-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--lemon);
    margin-left: 3px; margin-top: 6px; display: inline-block;
  }
  .footer-brand p { color: rgba(255,253,240,0.5); line-height: 1.7; font-size: 0.9rem; max-width: 340px; }
  .footer-col h4 {
    font-family: 'Montserrat', sans-serif; font-size: 0.78rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px; color: var(--lemon); margin-bottom: 20px;
  }
  .footer-col a {
    display: block; color: rgba(255,253,240,0.5);
    font-size: 0.9rem; margin-bottom: 12px;
    transition: color var(--transition);
  }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom {
    border-top: 1px solid rgba(255,253,240,0.1);
    padding: 24px 0; text-align: center;
    color: rgba(255,253,240,0.25); font-size: 0.82rem;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }

  /* ============= WA FLOAT ============= */
  .wa-float {
    position: fixed; bottom: 28px; right: 28px; z-index: 900;
    width: 56px; height: 56px; border-radius: 50%;
    background: #25D366; display: flex; align-items: center; justify-content: center;
    color: #fff; box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform var(--transition), box-shadow var(--transition);
    opacity: 0; pointer-events: none;
  }
  .wa-float.visible { opacity: 1; pointer-events: all; }
  .wa-float:hover { transform: scale(1.1); box-shadow: 0 10px 36px rgba(37,211,102,0.5); }

  /* ============= ANIMATIONS ============= */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Nav scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Burger
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('active');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });
  menu?.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      burger?.classList.remove('active');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Tabs
  document.querySelectorAll('.tour-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tour-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      const target = document.getElementById('tab-' + tab.dataset.tab);
      target?.classList.add('active');
    });
  });

  // Reviews carousel
  const track = document.getElementById('revTrack');
  document.getElementById('revPrev')?.addEventListener('click', () => {
    track?.scrollBy({ left: -440, behavior: 'smooth' });
  });
  document.getElementById('revNext')?.addEventListener('click', () => {
    track?.scrollBy({ left: 440, behavior: 'smooth' });
  });

  // WhatsApp float
  const waFloat = document.getElementById('waFloat');
  window.addEventListener('scroll', () => {
    waFloat?.classList.toggle('visible', window.scrollY > 400);
  });

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.about-grid, .tour-intro, .tour-desc-block, .boat-scroll, .cabrio-card, .exp-grid, .group-content, .masonry, .insta-handle, .reviews-carousel, .contacts-buttons').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });
</script>

</body>
</html>
