  .btn:hover { transform: translateY(-2px); }
  .btn svg { flex-shrink: 0; }

  .btn-sun {
    background: var(--terracotta);
    color: var(--white);
    box-shadow: 0 6px 24px rgba(196, 65, 37, 0.35);
  }
  .btn-sun:hover { box-shadow: 0 10px 32px rgba(196, 65, 37, 0.5); background: var(--terracotta-dark); }

  .btn-ghost {
    background: rgba(255,255,255,0.15);
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.4);
    backdrop-filter: blur(4px);
  }
  .btn-ghost:hover { border-color: var(--golden-light); color: var(--golden-light); }

  .btn-book {
    background: var(--terracotta);
    color: var(--white);
    box-shadow: 0 4px 16px rgba(196, 65, 37, 0.25);
    margin-top: 16px;
  }
  .btn-book:hover { box-shadow: 0 8px 24px rgba(196, 65, 37, 0.4); background: var(--terracotta-dark); }
  .btn-book.small { padding: 10px 22px; font-size: 0.85rem; margin-top: 12px; }

  /* Tour toggle */
  .tour-toggle {
    flex: 0 0 38px; width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid var(--sand);
    background: transparent;
    color: var(--espresso);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
    position: relative; font-size: 0;
  }
  .tour-toggle::before {
    content: '+';
    font-family: 'Cormorant', serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    color: var(--espresso);
    transition: transform 0.3s;
  }
  .tour-toggle.rotated::before { content: '\2212'; }
  .tour-toggle:hover { background: var(--honey); border-color: var(--golden-light); }
  .tour-toggle.small { flex: 0 0 28px; width: 28px; height: 28px; }
  .tour-toggle.small::before { font-size: 1.1rem; }

  .tour-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .tour-details.open { max-height: 5000px; }

  /* ========== NAVIGATION ========== */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 16px 24px;
    transition: background 0.4s, padding 0.4s, box-shadow 0.4s;
  }
  #nav.scrolled {
    background: rgba(255, 248, 239, 0.92);
    backdrop-filter: blur(16px);
    padding: 10px 24px;
    box-shadow: 0 4px 20px rgba(43, 26, 14, 0.06);
  }
  .nav-inner {
    max-width: 1080px; margin: 0 auto;
    display: flex; align-items: center; gap: 32px;
  }
  .logo {
    font-family: 'Cormorant', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--white);
    transition: color 0.4s;
  }
  #nav.scrolled .logo { color: var(--espresso); }
  .logo-dot { color: var(--terracotta); }

  .nav-links {
    display: flex; gap: 28px;
    margin-left: auto;
  }
  .nav-links a {
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    transition: color 0.3s;
    letter-spacing: 0.3px;
  }
  .nav-links a:hover { color: var(--golden-light); }
  #nav.scrolled .nav-links a { color: var(--taupe); }
  #nav.scrolled .nav-links a:hover { color: var(--terracotta); }

  .nav-wa {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    background: rgba(255,255,255,0.15);
    color: var(--white);
    border: 1.5px solid rgba(255,255,255,0.3);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .nav-wa:hover { background: rgba(255,255,255,0.25); }
  #nav.scrolled .nav-wa {
    background: var(--terracotta);
    color: var(--white);
    border-color: var(--terracotta);
  }
  #nav.scrolled .nav-wa:hover { background: var(--terracotta-dark); }

  .burger {
    display: none;
    flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: 4px;
  }
  .burger span {
    display: block; width: 24px; height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  #nav.scrolled .burger span { background: var(--espresso); }
  .burger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .burger.active span:nth-child(2) { opacity: 0; }
  .burger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  @media (max-width: 800px) {
    .nav-links, .nav-wa { display: none; }
    .burger { display: flex; }
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 99;
    background: rgba(43, 26, 14, 0.95);
    backdrop-filter: blur(20px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.4s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: auto; }
  .mobile-menu-inner { text-align: center; }
  .mobile-link {
    display: block;
    font-family: 'Cormorant', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--white);
    padding: 16px 0;
    transition: color 0.3s;
  }
  .mobile-link:hover { color: var(--golden); }
  .mobile-wa {
    margin-top: 24px;
    display: inline-flex; align-items: center; gap: 10px;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    background: #25D366;
    color: var(--white);
    font-weight: 700;
  }

  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .hero-img {
    position: absolute; inset: 0;
  }
  .hero-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
    animation: heroZoom 20s ease-in-out infinite alternate;
  }
  @keyframes heroZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }
  .hero-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      rgba(43, 26, 14, 0.7) 0%,
      rgba(43, 26, 14, 0.35) 35%,
      rgba(43, 26, 14, 0.1) 60%,
      transparent 100%
    );
  }
  .hero-content {
    position: relative; z-index: 2;
    padding: 0 32px 130px;
    max-width: 1080px;
    margin: 0 auto;
    width: 100%;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--golden-light);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .hero-badge svg { stroke: var(--golden-light); }
  .hero h1 {
    font-family: 'Cormorant', serif;
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 300;
    color: var(--white);
    line-height: 1.05;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }
  .hero-sub {
    font-family: 'Caveat', cursive;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.4;
    margin-bottom: 32px;
  }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-wave {
    position: absolute; bottom: -1px; left: 0; right: 0;
    z-index: 3; line-height: 0;
  }
  .hero-wave svg { width: 100%; height: 80px; }

  @media (max-width: 600px) {
    .hero-content { padding: 0 20px 100px; }
    .hero-wave svg { height: 50px; }
  }

  /* ========== ABOUT ========== */
  .about { background: var(--cream); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: center;
  }
  .about-photo-frame {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .about-photo-frame::after {
    content: '';
    position: absolute; inset: 0;
    border-radius: var(--radius);
    box-shadow: inset 0 0 0 1px rgba(230, 155, 48, 0.15);
    pointer-events: none;
  }
  .about-photo-frame img {
    width: 100%; height: 520px;
    object-fit: cover;
    object-position: center top;
  }
  .about-text .hand-label { font-size: 1.8rem; }
  .about-text h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    margin-bottom: 20px;
  }
  .about-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--taupe);
    margin-bottom: 14px;
  }
  .about-text blockquote {
    margin: 24px 0;
    padding: 20px 24px;
    background: var(--honey);
    border-radius: var(--radius-sm);
    font-family: 'Cormorant', serif;
    font-size: 1.4rem;
    font-weight: 500;
    font-style: italic;
    color: var(--espresso);
    position: relative;
  }
  .bq-mark { color: var(--golden); font-size: 1.6rem; }

  @media (max-width: 800px) {
    .about-grid { grid-template-columns: 1fr; gap: 36px; }
    .about-photo-frame img { height: 400px; }
  }

  /* ========== WAVE DIVIDERS ========== */
  .wave-divider { line-height: 0; margin-top: -1px; }
  .wave-divider svg { width: 100%; height: 50px; }
  .wave-cream-to-honey { background: var(--cream); }
  .wave-honey-to-cream { background: var(--honey); }

  /* ========== TOURS ========== */
  .tours-section { background: var(--honey); }

  .tour-category {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px;
    cursor: pointer;
    transition: background 0.3s;
  }
  .category-header:hover { background: rgba(254, 240, 214, 0.4); }
  .category-info {
    display: flex; align-items: center; gap: 16px;
  }
  .category-icon {
    flex: 0 0 52px;
    width: 52px; height: 52px;
    border-radius: 14px;
    background: var(--honey);
    display: flex; align-items: center; justify-content: center;
  }
  .category-info h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .category-tagline {
    font-size: 0.9rem;
    color: var(--taupe);
  }

  /* Tour card main (boat) */
  .tour-card-main { padding: 0 28px 28px; }
  .tour-meta {
    display: flex; flex-wrap: wrap; gap: 12px;
    margin-bottom: 16px;
  }
  .tour-meta-item {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--taupe);
    padding: 6px 14px;
    background: var(--cream);
    border-radius: 20px;
  }
  .tour-meta-item svg { width: 14px; height: 14px; stroke: var(--taupe); }
  .tour-meta-item.highlight { background: var(--honey); color: var(--golden); }
  .tour-meta.compact { gap: 8px; margin-bottom: 10px; }
  .tour-meta.compact span {
    font-size: 0.8rem; padding: 4px 12px;
    background: var(--cream); border-radius: 16px;
    font-weight: 600; color: var(--taupe);
  }
  .tour-meta.compact .highlight { color: var(--golden); background: var(--honey); }

  .tour-route {
    font-family: 'Cormorant', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--espresso);
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--sand);
  }
  .route-note { color: var(--taupe); font-size: 0.95rem; }

  .tour-description {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .tour-desc-item h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--espresso);
  }
  .tour-desc-item p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--taupe);
  }

  .boats-title {
    font-size: 1.3rem;
    font-weight: 500;
    margin-bottom: 16px;
  }

  /* Boat grid */
  .boat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 20px;
  }
  .boat-card {
    background: var(--cream);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s;
    position: relative;
  }
  .boat-card:hover { border-color: var(--golden-light); box-shadow: var(--shadow); }
  .boat-card.recommended { border-color: var(--golden); }
  .boat-badge {
    position: absolute; top: 10px; right: 10px; z-index: 2;
    font-family: 'Caveat', cursive;
    font-size: 0.9rem;
    color: var(--terracotta);
    background: var(--white);
    padding: 4px 12px;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .boat-img {
    height: 160px;
    background: var(--white);
    display: flex; align-items: center; justify-content: center;
    padding: 10px;
  }
  .boat-img img { max-height: 100%; width: auto; object-fit: contain; }
  .boat-info {
    padding: 14px 16px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .boat-info h5 {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .boat-spec { font-size: 0.8rem; color: var(--taupe); }
  .boat-price {
    font-family: 'Cormorant', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-top: 4px;
  }

  .tour-note {
    font-size: 0.85rem;
    color: var(--taupe);
    margin-bottom: 8px;
  }

  /* Cabrio tours */
  .cabrio-tour {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 0;
    margin-bottom: 20px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--cream);
  }
  .cabrio-tour:last-child { margin-bottom: 0; }
  .cabrio-tour-cover {
    min-height: 280px;
  }
  .cabrio-tour-cover img {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .cabrio-tour-body {
    padding: 24px 28px;
  }
  .cabrio-tour-body h4 {
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .cabrio-route {
    font-size: 0.9rem;
    color: var(--taupe);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .cabrio-toggle-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sea);
    margin-top: 8px;
  }
  .cabrio-toggle-header:hover { color: var(--terracotta); }

  .stops-list { padding: 12px 0; }
  .stop {
    padding: 12px 0;
    border-bottom: 1px solid var(--sand);
  }
  .stop:last-child { border-bottom: none; }
  .stop h5 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--terracotta);
    margin-bottom: 6px;
  }
  .stop p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--taupe);
  }
  .pricing-note {
    background: var(--honey);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    margin-top: 12px;
  }
  .pricing-note p {
    font-size: 0.85rem;
    color: var(--taupe);
    line-height: 1.6;
    margin-bottom: 4px;
  }
  .pricing-note p:last-child { margin-bottom: 0; }

  @media (max-width: 700px) {
    .cabrio-tour { grid-template-columns: 1fr; }
    .cabrio-tour-cover { min-height: 200px; }
    .tour-description { grid-template-columns: 1fr; }
    .boat-grid { grid-template-columns: 1fr; }
  }

  /* Experiences grid */
  .exp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  .exp-card {
    background: var(--cream);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow 0.3s;
  }
  .exp-card:hover { box-shadow: var(--shadow); }
  .exp-card-img {
    height: 200px;
    overflow: hidden;
  }
  .exp-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .exp-card:hover .exp-card-img img { transform: scale(1.04); }
  .exp-card-body {
    padding: 20px 22px;
  }
  .exp-card-body h4 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .exp-card-body p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--taupe);
    margin-bottom: 8px;
  }
  .exp-price-note {
    font-size: 0.8rem !important;
    color: var(--taupe) !important;
    font-style: italic;
  }

  .group-banner {
    background: linear-gradient(135deg, var(--espresso), #3D2A1A);
    border-radius: var(--radius-sm);
    padding: 36px 32px;
    text-align: center;
  }
  .group-banner h4 {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 10px;
  }
  .group-banner p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 20px;
  }
  .group-banner .btn-book { background: var(--golden); color: var(--espresso); }
  .group-banner .btn-book:hover { background: var(--golden-light); }

  @media (max-width: 700px) {
    .exp-grid { grid-template-columns: 1fr; }
  }

  /* ========== GALLERY ========== */
  .gallery-section { background: var(--cream); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 14px;
  }
  .gallery-item {
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
  }
  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .gallery-item:hover img { transform: scale(1.06); }
  .gi-tall { grid-row: span 2; }
  .gi-wide { grid-column: span 2; }

  @media (max-width: 700px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }
    .gi-tall { grid-row: span 1; }
    .gi-wide { grid-column: span 1; }
  }

  /* ========== REVIEWS ========== */
  .reviews-section { background: var(--honey); }
  .reviews-wrapper {
    position: relative;
    display: flex; align-items: center; gap: 12px;
  }
  .reviews-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 10px 0 20px;
    scrollbar-width: none;
  }
  .reviews-track::-webkit-scrollbar { display: none; }
  .review-card {
    flex: 0 0 360px;
    scroll-snap-align: start;
    background: var(--white);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.3s;
  }
  .review-card:hover { transform: translateY(-4px); }
  .review-card img {
    width: 100%;
    height: auto;
  }
  .review-arrow {
    flex: 0 0 44px;
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 2px solid var(--sand);
    background: var(--white);
    color: var(--espresso);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
  }
  .review-arrow:hover {
    background: var(--golden-light);
    border-color: var(--golden);
  }

  @media (max-width: 700px) {
    .review-card { flex: 0 0 300px; }
    .review-arrow { display: none; }
  }

  /* ========== FOOTER ========== */
  .footer { position: relative; }
  .footer-wave {
    line-height: 0;
    background: var(--honey);
  }
  .footer-wave svg { width: 100%; height: 70px; }
  .footer-body {
    background: var(--espresso);
    padding: 60px 24px 30px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }
  .footer-logo {
    font-family: 'Cormorant', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    display: block;
    margin-bottom: 12px;
  }
  .footer-brand p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
  }
  .footer-links h5, .footer-contact h5 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--golden);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .footer-links a {
    display: block;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    padding: 6px 0;
    transition: color 0.3s;
  }
  .footer-links a:hover { color: var(--white); }
  .footer-btn {
    display: inline-flex; align-items: center; gap: 8px;
