---
import { MapPin } from 'lucide-astro';
---

<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-gradient"></div>
  <div class="hero-accent-glow"></div>

  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-geo">
        <MapPin size={13} />
        <span>Амальфитанское побережье, Италия</span>
      </div>
      <div class="hero-title-wrap">
        <span class="hero-accent-line"></span>
        <h1>Авторские<br>экскурсии</h1>
      </div>
      <p class="hero-tagline">которые становятся лучшей частью вашей поездки в&nbsp;Италию</p>
      <div class="hero-buttons">
        <a href="#tours" class="btn btn-primary">
          Мои экскурсии
        </a>
        <a href="https://wa.me/393792811354" class="btn btn-whatsapp" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.553 4.12 1.52 5.855L.053 23.52l5.797-1.447A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.91 0-3.74-.51-5.33-1.45l-.38-.23-3.44.86.9-3.36-.25-.39A9.8 9.8 0 012.18 12c0-5.41 4.41-9.82 9.82-9.82 5.41 0 9.82 4.41 9.82 9.82 0 5.41-4.41 9.82-9.82 9.82z"/></svg>
        </a>
        <a href="https://t.me/ann_in_rome" class="btn btn-telegram" target="_blank" rel="noopener" aria-label="Telegram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Full background photo — anchored right-bottom, no darkening */
  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/images/cabrio-classic.jpg') right bottom / cover no-repeat;
    animation: heroKenBurns 30s ease-in-out infinite alternate;
  }
  @keyframes heroKenBurns {
    0% { transform: scale(1); }
    100% { transform: scale(1.05) translate(-8px, -4px); }
  }

  /* Warm cream gradient from left — text readability without darkening the photo */
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(253,248,240, 0.97) 0%,
      rgba(253,248,240, 0.93) 20%,
      rgba(253,248,240, 0.75) 38%,
      rgba(253,248,240, 0.3) 52%,
      transparent 62%
    );
    z-index: 1;
  }

  /* Subtle warm accent glow — lemon/golden warmth at bottom-left */
  .hero-accent-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse at 5% 90%, rgba(244,208,63,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 15% 30%, rgba(170,34,2,0.06) 0%, transparent 40%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1140px;
    margin: 0 auto;
    padding: 140px 48px 100px;
    width: 100%;
  }

  .hero-text {
    max-width: 460px;
  }

  /* Geo badge */
  .hero-geo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--blue);
    margin-bottom: 24px;
    padding: 6px 16px 6px 12px;
    background: var(--white);
    border-radius: 50px;
    box-shadow: 0 2px 12px rgba(27,58,92,0.08);
  }

  /* Accent line above title */
  .hero-title-wrap {
    position: relative;
  }
  .hero-accent-line {
    display: block;
    width: 48px;
    height: 3px;
    background: linear-gradient(90deg, var(--coral), var(--yellow));
    border-radius: 2px;
    margin-bottom: 20px;
  }

  .hero-text h1 {
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: 900;
    color: #aa2202;
    margin-bottom: 16px;
    line-height: 1.08;
    letter-spacing: -1.5px;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: #5a6a7a;
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 380px;
  }

  .hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }
  .hero .btn-primary {
    background: #aa2202;
    box-shadow: 0 8px 28px rgba(123,4,28,0.3);
  }
  .hero .btn-primary:hover {
    box-shadow: 0 12px 36px rgba(123,4,28,0.45);
  }
  .btn-whatsapp, .btn-telegram {
    padding: 14px !important;
    gap: 0 !important;
  }
  .btn-whatsapp {
    background: #25D366 !important;
    color: var(--white) !important;
    border: none !important;
    box-shadow: 0 8px 28px rgba(37,211,102,0.3);
  }
  .btn-whatsapp:hover {
    box-shadow: 0 12px 36px rgba(37,211,102,0.45) !important;
  }
  .btn-telegram {
    background: #0088cc !important;
    color: var(--white) !important;
    border: none !important;
    box-shadow: 0 8px 28px rgba(0,136,204,0.3);
  }
  .btn-telegram:hover {
    box-shadow: 0 12px 36px rgba(0,136,204,0.45) !important;
  }

  /* ---- Mobile ---- */
  @media (max-width: 900px) {
    .hero {
      min-height: 100vh;
    }
    .hero-bg {
      background-position: 65% center;
    }
    .hero-gradient {
      background: linear-gradient(
        180deg,
        rgba(253,248,240, 0.95) 0%,
        rgba(253,248,240, 0.85) 30%,
        rgba(253,248,240, 0.3) 55%,
        transparent 70%,
        transparent 85%,
        rgba(253,248,240, 0.7) 95%,
        rgba(253,248,240, 0.9) 100%
      );
    }
    .hero-inner {
      padding: 100px 24px 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .hero-text {
      max-width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      flex: 1;
    }
    .hero-geo {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-accent-line {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-tagline {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-buttons {
      justify-content: center;
      margin-top: auto;
      padding-bottom: 36px;
    }
    .hero-text h1 {
      font-size: 2.4rem;
    }
  }
  @media (max-width: 480px) {
    .hero-text h1 {
      font-size: 2rem;
    }
  }
</style>
