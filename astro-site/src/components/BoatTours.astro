---
import { Users, Sun, Sparkles, Compass, ChevronDown } from 'lucide-astro';
---

<section class="section boats" id="tours">
  <div class="container">
    <div class="section-header reveal">
      <h2>Мои экскурсии</h2>
    </div>

    <!-- Boat Tour - Морской хит -->
    <div class="tour-block reveal" id="boat-tour">
      <div class="tour-block-header" data-toggle="boat-tour-content">
        <div class="tour-block-title">
          <h3>На лодке &mdash; &laquo;Морской хит&raquo;</h3>
          <span class="tour-block-brief">Амальфитанское побережье с моря &mdash; совсем другая история</span>
        </div>
        <button class="tour-toggle" aria-label="Свернуть/развернуть">
          <ChevronDown size={20} />
        </button>
      </div>
      <div class="tour-block-content open" id="boat-tour-content">
        <div class="tour-info">
          <div class="tour-meta-row">
            <span><Sun size={15} /> 4 часа</span>
            <span><Sparkles size={15} /> Просекко включено</span>
            <span><Compass size={15} /> Маршрут можно настроить</span>
          </div>
        </div>

        <div class="tour-description">
          <p>Минори &mdash; Атрани &mdash; Амальфи &mdash; Прайано &mdash; Позитано. Скалы, каскады домиков и&nbsp;уединённые бухты&nbsp;&mdash; всё это откроется с&nbsp;борта яхты, вдали от&nbsp;суеты и&nbsp;толп. Остановки у&nbsp;пляжей, куда невозможно добраться по&nbsp;суше. Купание в&nbsp;бирюзовой воде и&nbsp;пикник с&nbsp;просекко. Разноцветные домики Позитано, белоснежный Прайано, роскошный Амальфи&nbsp;&mdash; часть вашей морской сказки.</p>
        </div>

        <h4 class="tour-sub-heading">Стоимость зависит от вида лодки</h4>

        <div class="boat-grid">
          <div class="boat-card">
            <div class="boat-img">
              <img src="/images/perla_blu.png" alt="Лодка Perla Blu" loading="lazy">
            </div>
            <div class="boat-body">
              <h4>Perla Blu</h4>
              <div class="boat-specs">
                <span><Users size={14} /> макс. 3 чел.</span>
              </div>
              <div class="boat-price">&euro;700</div>
              <a href="https://wa.me/393792811354" class="boat-cta" target="_blank" rel="noopener">
                Забронировать &rarr;
              </a>
            </div>
          </div>

          <div class="boat-card boat-card--featured">
            <div class="boat-badge">
              <Sparkles size={12} /> Рекомендую
            </div>
            <div class="boat-img">
              <img src="/images/cranchi%20sport.png" alt="Лодка Cranchi Sport" loading="lazy">
            </div>
            <div class="boat-body">
              <h4>Cranchi Sport</h4>
              <div class="boat-specs">
                <span><Users size={14} /> макс. 7 чел.</span>
              </div>
              <div class="boat-price">&euro;850</div>
              <a href="https://wa.me/393792811354" class="boat-cta" target="_blank" rel="noopener">
                Забронировать &rarr;
              </a>
            </div>
          </div>

          <div class="boat-card">
            <div class="boat-img">
              <img src="/images/reginella.png" alt="Лодка Reginella" loading="lazy">
            </div>
            <div class="boat-body">
              <h4>Reginella</h4>
              <div class="boat-specs">
                <span><Users size={14} /> макс. 6 чел.</span>
              </div>
              <div class="boat-price">&euro;850</div>
              <a href="https://wa.me/393792811354" class="boat-cta" target="_blank" rel="noopener">
                Забронировать &rarr;
              </a>
            </div>
          </div>
        </div>

        <div class="tour-departure">
          <strong>Отправление:</strong> Амальфи, Минори, Майори
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const targetId = header.getAttribute('data-toggle');
      if (!targetId) return;
      const content = document.getElementById(targetId);
      if (!content) return;
      content.classList.toggle('open');
      const toggle = header.querySelector('.tour-toggle');
      if (toggle) toggle.classList.toggle('rotated');
    });
  });
</script>

<style>
  .boats { background: var(--light); }

  .tour-block {
    max-width: 960px;
    margin: 0 auto 32px;
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .tour-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 32px;
    cursor: pointer;
    user-select: none;
    transition: background 0.3s;
  }
  .tour-block-header:hover {
    background: rgba(27,58,92,0.02);
  }

  .tour-block-title h3 {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 4px;
  }
  .tour-block-brief {
    font-size: 0.9rem;
    color: #888;
  }

  .tour-toggle {
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(27,58,92,0.12);
    background: transparent;
    color: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s, background 0.3s;
  }
  .tour-toggle:hover {
    background: rgba(27,58,92,0.05);
  }
  .tour-toggle.rotated {
    transform: rotate(180deg);
  }

  .tour-block-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }
  .tour-block-content.open {
    max-height: 2000px;
  }

  .tour-info {
    padding: 0 32px;
  }

  .tour-meta-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .tour-meta-row span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    color: #888;
    font-weight: 500;
  }

  .tour-description {
    padding: 0 32px 20px;
  }
  .tour-description p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.75;
  }

  .tour-sub-heading {
    padding: 0 32px 16px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--blue);
  }

  .boat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 0 32px;
    margin-bottom: 24px;
  }
  .boat-card {
    background: var(--light);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    position: relative;
  }
  .boat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .boat-card--featured {
    border: 2px solid rgba(255,107,107,0.2);
  }
  .boat-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    background: var(--coral);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 50px;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .boat-img {
    height: 180px;
    overflow: hidden;
    background: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .boat-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .boat-card:hover .boat-img img { transform: scale(1.05); }
  .boat-body { padding: 18px 20px 20px; }
  .boat-body h4 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 6px;
  }
  .boat-specs {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
    font-size: 0.8rem;
    color: #888;
  }
  .boat-specs span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .boat-price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--blue);
    margin-bottom: 10px;
  }
  .boat-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    color: var(--coral);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: gap var(--transition);
  }
  .boat-cta:hover { gap: 10px; }

  .tour-departure {
    padding: 16px 32px 28px;
    font-size: 0.9rem;
    color: #666;
  }
  .tour-departure strong {
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .boat-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .boat-grid { grid-template-columns: 1fr; }
    .tour-block-header { padding: 20px 20px; }
    .tour-info, .tour-description, .tour-departure, .tour-sub-heading { padding-left: 20px; padding-right: 20px; }
    .boat-grid { padding: 0 20px; }
    .tour-meta-row { flex-direction: column; gap: 8px; }
  }
</style>
