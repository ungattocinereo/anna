---
import { Instagram, MessageCircle, Mail, Heart, Send, Compass, Ship, Camera, Star } from 'lucide-astro';
---

<footer class="footer">
  <div class="footer-bg" aria-hidden="true"></div>
  <div class="footer-grid">
    <div class="footer-brand">
      <h3 class="footer-logo">ANNA<span class="footer-logo-dot"></span></h3>
      <p>
        <Heart size={14} class="footer-inline-icon" />
        Авторские экскурсии по Амальфитанскому побережью. Лодочные прогулки, кабриолеты, кулинарные мастер-классы и незабываемые впечатления.
      </p>
      <div class="footer-socials">
        <a href="https://www.instagram.com/ann_in_rome/" target="_blank" rel="noopener" aria-label="Instagram">
          <Instagram size={18} />
        </a>
        <a href="https://wa.me/393792811354" target="_blank" rel="noopener" aria-label="WhatsApp">
          <MessageCircle size={18} />
        </a>
        <a href="https://t.me/ann_in_rome" target="_blank" rel="noopener" aria-label="Telegram">
          <Send size={18} />
        </a>
        <a href="mailto:a.aharodnikava@gmail.com" aria-label="Email">
          <Mail size={18} />
        </a>
      </div>
    </div>
    <div>
      <h4>Навигация</h4>
      <div class="footer-links">
        <a href="#about"><Compass size={13} /> Обо мне</a>
        <a href="#boats"><Ship size={13} /> Экскурсии</a>
        <a href="#gallery"><Camera size={13} /> Галерея</a>
        <a href="#reviews"><Star size={13} /> Отзывы</a>
      </div>
    </div>
    <div>
      <h4>Контакты</h4>
      <div class="footer-links">
        <a href="https://wa.me/393792811354" target="_blank" rel="noopener">
          <MessageCircle size={13} /> WhatsApp
        </a>
        <a href="https://www.instagram.com/ann_in_rome/" target="_blank" rel="noopener">
          <Instagram size={13} /> Instagram
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span>&copy; 2026 Anna &mdash; Авторские экскурсии по Амальфитанскому побережью</span>
      <div class="footer-legal">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Условия использования</a>
      </div>
    </div>
  </div>
</footer>

<!-- WhatsApp floating button -->
<a href="https://wa.me/393792811354" class="whatsapp-float" target="_blank" rel="noopener" aria-label="Написать в WhatsApp">
  <svg viewBox="0 0 24 24" fill="currentColor" width="30" height="30"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<style>
  .footer {
    position: relative;
    background: var(--dark);
    padding: 80px 24px 0;
    overflow: hidden;
  }
  .footer-bg {
    position: absolute;
    inset: 0;
    background:
      url('/images/20241030_123632.jpg') center / cover no-repeat;
    opacity: 0.04;
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    max-width: 1100px;
    margin: 0 auto 60px;
    position: relative;
    z-index: 1;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: 2px;
    display: inline-flex;
    align-items: flex-start;
  }
  .footer-logo-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--coral);
    margin-left: 3px;
    margin-top: 6px;
    display: inline-block;
  }

  .footer-brand p {
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 360px;
    font-size: 0.9rem;
  }
  .footer-inline-icon {
    display: inline;
    vertical-align: middle;
    margin-right: 2px;
    color: var(--coral);
  }

  .footer-socials {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }
  .footer-socials a {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.7);
    transition: all var(--transition);
  }
  .footer-socials a:hover {
    background: var(--coral);
    border-color: var(--coral);
    color: var(--white);
    transform: translateY(-3px);
  }

  .footer h4 {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--yellow);
    margin-bottom: 24px;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 14px;
    font-size: 0.9rem;
    transition: color var(--transition), gap var(--transition);
  }
  .footer-links a:hover { color: var(--white); gap: 12px; }

  .footer-bottom {
    position: relative;
    z-index: 1;
    background: rgba(0,0,0,0.3);
    margin: 0 -24px;
    padding: 24px 24px;
  }
  .footer-bottom-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    color: rgba(255,255,255,0.25);
    font-size: 0.82rem;
  }
  .footer-legal {
    display: flex;
    gap: 24px;
  }
  .footer-legal a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.3);
    transition: color var(--transition);
    font-size: 0.8rem;
  }
  .footer-legal a:hover { color: rgba(255,255,255,0.6); }

  /* WhatsApp floating */
  .whatsapp-float {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 900;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform var(--transition), box-shadow var(--transition);
    animation: whatsappPulse 2.5s infinite;
  }
  .whatsapp-float:hover {
    transform: scale(1.1);
    box-shadow: 0 10px 36px rgba(37,211,102,0.5);
    animation: none;
  }
  @keyframes whatsappPulse {
    0% { box-shadow: 0 6px 24px rgba(37,211,102,0.4); }
    50% { box-shadow: 0 6px 24px rgba(37,211,102,0.4), 0 0 0 10px rgba(37,211,102,0.12); }
    100% { box-shadow: 0 6px 24px rgba(37,211,102,0.4); }
  }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
  }
  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom-inner { flex-direction: column; text-align: center; }
    .footer-legal { justify-content: center; }
    .whatsapp-float { bottom: 20px; right: 20px; width: 52px; height: 52px; }
  }
</style>
