<style>
  /* Contacts section */
  .contacts {
    background: var(--white);
    padding: 80px 24px;
  }
  .contacts-title {
    color: var(--blue) !important;
  }
  .contacts-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    max-width: 700px;
    margin: 0 auto;
  }
  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--white);
    transition: transform var(--transition), box-shadow var(--transition);
    letter-spacing: 0.3px;
  }
  .contact-btn:hover {
    transform: translateY(-3px);
    color: var(--white);
  }
  .contact-btn--whatsapp {
    background: #25D366;
    box-shadow: 0 8px 24px rgba(37,211,102,0.3);
  }
  .contact-btn--whatsapp:hover {
    box-shadow: 0 12px 32px rgba(37,211,102,0.45);
  }
  .contact-btn--telegram {
    background: #0088cc;
    box-shadow: 0 8px 24px rgba(0,136,204,0.3);
  }
  .contact-btn--telegram:hover {
    box-shadow: 0 12px 32px rgba(0,136,204,0.45);
  }
  .contact-btn--instagram {
    background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737);
    box-shadow: 0 8px 24px rgba(131,58,180,0.3);
  }
  .contact-btn--instagram:hover {
    box-shadow: 0 12px 32px rgba(131,58,180,0.45);
  }

  /* Footer */
  .footer {
    position: relative;
    background: var(--dark);
    padding: 80px 24px 0;
    overflow: hidden;
  }
  .footer-bg {
    position: absolute;
    inset: 0;
    background:
      url('/images/20241030_123632.jpg') center / cover no-repeat;
    opacity: 0.04;
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    max-width: 1100px;
    margin: 0 auto 60px;
    position: relative;
    z-index: 1;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: 2px;
    display: inline-flex;
    align-items: flex-start;
  }
  .footer-logo-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--coral);
    margin-left: 3px;
    margin-top: 6px;
    display: inline-block;
  }

  .footer-brand p {
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 360px;
    font-size: 0.9rem;
  }
  .footer-inline-icon {
    display: inline;
    vertical-align: middle;
    margin-right: 2px;
    color: var(--coral);
  }

  .footer h4 {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--yellow);
    margin-bottom: 24px;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 14px;
    font-size: 0.9rem;
    transition: color var(--transition), gap var(--transition);
  }
  .footer-links a:hover { color: var(--white); gap: 12px; }

  .footer-bottom {
    position: relative;
    z-index: 1;
    background: rgba(0,0,0,0.3);
    margin: 0 -24px;
    padding: 24px 24px;
  }
  .footer-bottom-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    color: rgba(255,255,255,0.25);
    font-size: 0.82rem;
  }
  .footer-legal {
    display: flex;
    gap: 24px;
  }
  .footer-legal a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.3);
    transition: color var(--transition);
    font-size: 0.8rem;
  }
  .footer-legal a:hover { color: rgba(255,255,255,0.6); }

  /* WhatsApp floating */
  .whatsapp-float {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 900;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    box-shadow: 0 6px 24px rgba(37,211,102,0.4);
    transition: transform var(--transition), box-shadow var(--transition), opacity 0.4s ease;
    animation: whatsappPulse 2.5s infinite;
    opacity: 0;
    pointer-events: none;
  }
  :global(.whatsapp-float.visible) {
    opacity: 1;
    pointer-events: all;
  }
  .whatsapp-float:hover {
    transform: scale(1.1);
    box-shadow: 0 10px 36px rgba(37,211,102,0.5);
    animation: none;
  }
  @keyframes whatsappPulse {
    0% { box-shadow: 0 6px 24px rgba(37,211,102,0.4); }
    50% { box-shadow: 0 6px 24px rgba(37,211,102,0.4), 0 0 0 10px rgba(37,211,102,0.12); }
    100% { box-shadow: 0 6px 24px rgba(37,211,102,0.4); }
  }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
  }
  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom-inner { flex-direction: column; text-align: center; }
    .footer-legal { justify-content: center; }
    .whatsapp-float { bottom: 20px; right: 20px; width: 52px; height: 52px; }
    .contacts-buttons { flex-direction: column; align-items: center; }
    .contact-btn { width: 100%; max-width: 300px; justify-content: center; }
  }
</style>
