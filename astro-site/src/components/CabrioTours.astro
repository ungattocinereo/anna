---
import { Car, Clock, Users, MapPin, Euro, Ticket, ChevronDown } from 'lucide-astro';
---

<section class="section cabrio" id="cabrio">
  <div class="container">

    <!-- Вечная классика -->
    <div class="tour-block reveal">
      <div class="tour-block-header" data-toggle="classic-content">
        <div class="tour-block-title">
          <h3>На кабриолете &mdash; &laquo;Вечная классика&raquo;</h3>
          <span class="tour-block-brief">Серпантины, панорамы и ветер в волосах</span>
        </div>
        <button class="tour-toggle" aria-label="Свернуть/развернуть">
          <ChevronDown size={20} />
        </button>
      </div>
      <div class="tour-block-content open" id="classic-content">
        <div class="tour-info">
          <div class="tour-meta-row">
            <span><Clock size={15} /> 9 часов</span>
            <span><Users size={15} /> до 3 человек</span>
          </div>
        </div>

        <div class="tour-description">
          <p class="tour-route"><MapPin size={15} /> Позитано &mdash; Праяно &mdash; Равелло &mdash; долина Трамонти &mdash; Майори &mdash; Минори &mdash; Атрани &mdash; Амальфи</p>
          <p><strong>Позитано</strong> &mdash; жемчужина побережья. Остановки на&nbsp;двух живописных смотровых площадках. Легенды о&nbsp;Позитано и&nbsp;знакомство со&nbsp;знаменитым синьором Сальватором.</p>
          <p><strong>Равелло</strong> &mdash; элегантный городок с&nbsp;душой музыки. Прогулка по&nbsp;садам виллы Чимброне с&nbsp;головокружительным видом (365 метров над морем!).</p>
          <p><strong>Долина Трамонти</strong> &mdash; скрытая от&nbsp;туристов долина виноградников и&nbsp;лимонов. Частная сыроварня со&nbsp;свежайшей домашней моцареллой.</p>
          <p><strong>Атрани</strong> &mdash; самый маленький город Италии. Узкие улочки, лодки у&nbsp;берега и&nbsp;ощущение затерянности во&nbsp;времени. Прямо как в&nbsp;сериале &laquo;Рипли&raquo;!</p>
          <p><strong>Амальфи</strong> &mdash; историческая морская республика с&nbsp;величественным собором. Старинные улочки и&nbsp;обязательное лимонное джелато!</p>
        </div>

        <div class="tour-pricing">
          <div class="tour-pricing-row">
            <div class="tour-pricing-main">
              <div class="price-value">&euro;550</div>
              <div class="price-note"><Ticket size={13} /> + &euro;12/чел. вход на виллу Чимброне</div>
            </div>
            <div class="tour-pricing-pickup">
              <strong><Car size={14} /> Забор:</strong>
              Амальфи &mdash; бесплатно &middot;
              Сорренто, Салерно &mdash; &euro;50 &middot;
              Неаполь &mdash; &euro;100
            </div>
            <a href="https://wa.me/393792811354" class="btn btn-primary btn-sm" target="_blank" rel="noopener">Забронировать</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Элегантная роскошь -->
    <div class="tour-block reveal">
      <div class="tour-block-header" data-toggle="luxury-content">
        <div class="tour-block-title">
          <h3>На кабриолете &mdash; &laquo;Элегантная роскошь&raquo;</h3>
          <span class="tour-block-brief">Позитано и Сорренто в стиле dolce vita</span>
        </div>
        <button class="tour-toggle" aria-label="Свернуть/развернуть">
          <ChevronDown size={20} />
        </button>
      </div>
      <div class="tour-block-content open" id="luxury-content">
        <div class="tour-info">
          <div class="tour-meta-row">
            <span><Clock size={15} /> 8 часов</span>
            <span><Users size={15} /> до 3 человек</span>
          </div>
        </div>

        <div class="tour-description">
          <p class="tour-route"><MapPin size={15} /> Позитано &mdash; Сорренто</p>
          <p><strong>Позитано</strong> &mdash; легендарный город-символ Амальфи. Живописные улочки к&nbsp;морю, знаменитые панорамы. Посещение древней Римской виллы (музей MAR) с&nbsp;уникальными фресками.</p>
          <p><strong>Сорренто</strong> &mdash; элегантный город на&nbsp;скалах с&nbsp;видом на&nbsp;Везувий. Атмосферный исторический центр, уютные улочки и&nbsp;панорамные террасы. Идеальное сочетание шарма и&nbsp;dolce vita.</p>
        </div>

        <div class="tour-pricing">
          <div class="tour-pricing-row">
            <div class="tour-pricing-main">
              <div class="price-value">&euro;550</div>
              <div class="price-note"><Ticket size={13} /> + &euro;15/чел. вход на виллу MAR</div>
            </div>
            <div class="tour-pricing-pickup">
              <strong><Car size={14} /> Забор:</strong>
              Амальфи, Сорренто &mdash; бесплатно &middot;
              Салерно &mdash; &euro;50 &middot;
              Неаполь &mdash; &euro;100
            </div>
            <a href="https://wa.me/393792811354" class="btn btn-primary btn-sm" target="_blank" rel="noopener">Забронировать</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.cabrio [data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const targetId = header.getAttribute('data-toggle');
      if (!targetId) return;
      const content = document.getElementById(targetId);
      if (!content) return;
      content.classList.toggle('open');
      const toggle = header.querySelector('.tour-toggle');
      if (toggle) toggle.classList.toggle('rotated');
    });
  });
</script>

<style>
  .cabrio { background: var(--white); }

  .tour-block {
    max-width: 960px;
    margin: 0 auto 32px;
    background: var(--light);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    border: 1px solid rgba(27,58,92,0.06);
  }

  .tour-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 32px;
    cursor: pointer;
    user-select: none;
    transition: background 0.3s;
  }
  .tour-block-header:hover {
    background: rgba(27,58,92,0.02);
  }

  .tour-block-title h3 {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 4px;
  }
  .tour-block-brief {
    font-size: 0.9rem;
    color: #888;
  }

  .tour-toggle {
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(27,58,92,0.12);
    background: transparent;
    color: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s, background 0.3s;
  }
  .tour-toggle:hover {
    background: rgba(27,58,92,0.05);
  }
  .tour-toggle.rotated {
    transform: rotate(180deg);
  }

  .tour-block-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }
  .tour-block-content.open {
    max-height: 2000px;
  }

  .tour-info {
    padding: 0 32px;
  }

  .tour-meta-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .tour-meta-row span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    color: #888;
    font-weight: 500;
  }

  .tour-description {
    padding: 0 32px 16px;
  }
  .tour-description p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.75;
    margin-bottom: 10px;
  }
  .tour-description p:last-child {
    margin-bottom: 0;
  }
  .tour-route {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    color: var(--coral) !important;
    margin-bottom: 16px !important;
  }

  .tour-pricing {
    padding: 0 32px 28px;
  }
  .tour-pricing-row {
    background: var(--white);
    border-radius: 12px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .price-value {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--blue);
    margin-bottom: 4px;
  }
  .price-note {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.82rem;
    color: #888;
  }
  .tour-pricing-pickup {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.6;
  }
  .tour-pricing-pickup strong {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--blue);
  }

  .btn-sm {
    padding: 12px 24px !important;
    font-size: 0.85rem !important;
  }

  @media (max-width: 768px) {
    .tour-block-header { padding: 20px 20px; }
    .tour-info, .tour-description, .tour-pricing { padding-left: 20px; padding-right: 20px; }
    .tour-pricing-row { flex-direction: column; text-align: center; align-items: stretch; }
    .tour-block-title h3 { font-size: 1.1rem; }
    .tour-meta-row { justify-content: flex-start; gap: 12px; }
  }
</style>
